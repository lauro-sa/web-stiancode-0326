---
// ============================================================
// Plantilla.astro — Layout base de stiancode.dev
// ============================================================
interface Props {
  titulo:      string;
  descripcion: string;
  imagen?:     string;
}

const { titulo, descripcion, imagen = '/og-image.png' } = Astro.props;
const urlCanonica = Astro.url.href;
---

<!DOCTYPE html>
<html lang="es" data-tema="oscuro">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="theme-color" content="#8964e8"/>
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png"/>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
  <title>{titulo}</title>
  <meta name="description"  content={descripcion}/>
  <meta name="keywords"     content="S7ian Code, desarrollo web, aplicaciones PWA, React, Firebase, full-stack"/>
  <meta name="author"       content="S7ian Code"/>
  <meta name="robots"       content="index, follow"/>
  <link rel="canonical"     href={urlCanonica}/>
  <!-- Open Graph — WhatsApp, Facebook, LinkedIn -->
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content={urlCanonica}/>
  <meta property="og:title"       content={titulo}/>
  <meta property="og:description" content={descripcion}/>
  <meta property="og:image"       content={new URL(imagen, 'https://stiancode.dev').href}/>
  <meta property="og:image:width"  content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:locale"      content="es"/>
  <meta property="og:site_name"   content="S7ian Code"/>
  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content={titulo}/>
  <meta name="twitter:description" content={descripcion}/>
  <meta name="twitter:image"       content={new URL(imagen, 'https://stiancode.dev').href}/>

  <script type="application/ld+json">
    {JSON.stringify({
      "@context":    "https://schema.org",
      "@type":       "Person",
      "name":        "S7ian Code",
      "url":         "https://stiancode.dev",
      "jobTitle":    "Desarrollador Full-Stack",
      "sameAs":      ["https://github.com/lauro-sa", "https://www.linkedin.com/in/laurosa/"]
    })}
  </script>

  <!-- Google Analytics — REEMPLAZAR G-XXXXXXXXXX -->
  <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script> -->
  <!-- Meta Pixel — REEMPLAZAR PIXEL_ID -->
  <!-- <script>fbq('init','PIXEL_ID');</script> -->

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet"/>
</head>

<body>
  <div id="barra-progreso" style="position:fixed;top:0;left:0;height:2px;width:0;background:var(--texto);z-index:300;transition:background .5s"></div>
  <!-- Canvas de partículas movido al Hero -->
  <slot/>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  import { iniciarToggleTema, iniciarMenuMobile, iniciarBarraProgreso, iniciarNavScroll, iniciarSmoothScroll, iniciarAnimacionIconos, iniciarTypewriter } from '../scripts/utilidades.js';
  import { iniciarParticulas } from '../scripts/particulas.js';

  document.addEventListener('DOMContentLoaded', () => {
    iniciarToggleTema('boton-tema', 'sc-tema', ['boton-tema-mobile']);
    iniciarMenuMobile('boton-hamburguesa', 'menu-mobile');
    iniciarBarraProgreso('barra-progreso');
    iniciarNavScroll('nav-principal');
    iniciarSmoothScroll();
    iniciarAnimacionIconos('.tarjeta-servicio, .fila-proyecto');
    iniciarTypewriter();
    iniciarParticulas('canvas-particulas-hero');
  });

  // Animación del hero
  window.addEventListener('load', () => {
    const kf = document.createElement('style');
    kf.textContent = `
      @keyframes subirLinea { from { opacity:0; transform:translateY(100%); } to { opacity:1; transform:none; } }
      .linea-titulo { opacity: 0; }
    `;
    document.head.appendChild(kf);

    const badge = document.querySelector('.hero-badge');
    if (badge) { badge.style.transition = 'opacity .6s ease'; badge.style.opacity = '1'; }

    document.querySelectorAll('.linea-titulo').forEach((el, i) => {
      el.style.animation = `subirLinea .85s ${0.2 + i * 0.13}s cubic-bezier(0.16,1,0.3,1) forwards`;
    });

    setTimeout(() => {
      const sub  = document.querySelector('.hero-subtitulo');
      const btns = document.querySelector('.hero-botones');
      if (sub)  { sub.style.transition  = 'opacity .7s ease'; sub.style.opacity  = '1'; }
      if (btns) { btns.style.transition = 'opacity .7s ease'; btns.style.opacity = '1'; }
    }, 500);
  });
</script>
