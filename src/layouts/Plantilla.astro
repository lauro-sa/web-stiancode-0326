---
// ============================================================
// Plantilla.astro — Layout base de stiancode.dev
// ============================================================
import { getLangFromUrl, getLocalizedUrl } from '../i18n/utils.js';

interface Props {
  titulo:      string;
  descripcion: string;
  imagen?:     string;
  lang?:       'es' | 'en';
}

const langDetectado = getLangFromUrl(Astro.url);
const { titulo, descripcion, imagen = '/og-image.png', lang = langDetectado } = Astro.props;
const urlCanonica = Astro.url.href;
const ogLocale = lang === 'en' ? 'en' : 'es';
const otroLang = lang === 'en' ? 'es' : 'en';
const urlAlterna = new URL(getLocalizedUrl(Astro.url, otroLang), 'https://stiancode.dev').href;
const urlEs = lang === 'es' ? urlCanonica : urlAlterna;
const urlEn = lang === 'en' ? urlCanonica : urlAlterna;
---

<!DOCTYPE html>
<html lang={lang} data-tema="oscuro">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <meta name="theme-color" content="#0c1018"/>
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png"/>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"/>
  <title>{titulo}</title>
  <meta name="description"  content={descripcion}/>
  <meta name="keywords"     content="S7ian Code, desarrollo web, aplicaciones PWA, React, Firebase, full-stack"/>
  <meta name="author"       content="S7ian Code"/>
  <meta name="robots"       content="index, follow"/>
  <link rel="canonical"     href={urlCanonica}/>
  <!-- Hreflang — SEO multilingüe -->
  <link rel="alternate" hreflang="es" href={urlEs}/>
  <link rel="alternate" hreflang="en" href={urlEn}/>
  <link rel="alternate" hreflang="x-default" href={urlEs}/>
  <!-- Open Graph — WhatsApp, Facebook, LinkedIn -->
  <meta property="og:type"        content="website"/>
  <meta property="og:url"         content={urlCanonica}/>
  <meta property="og:title"       content={titulo}/>
  <meta property="og:description" content={descripcion}/>
  <meta property="og:image"       content={new URL(imagen, 'https://stiancode.dev').href}/>
  <meta property="og:image:width"  content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:locale"      content={ogLocale}/>
  <meta property="og:site_name"   content="S7ian Code"/>
  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content={titulo}/>
  <meta name="twitter:description" content={descripcion}/>
  <meta name="twitter:image"       content={new URL(imagen, 'https://stiancode.dev').href}/>

  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ProfessionalService",
          "name": "S7ian Code",
          "url": "https://stiancode.dev",
          "logo": "https://stiancode.dev/logo-claro.png",
          "description": lang === 'en'
            ? "Professional web development: custom sites, PWA apps and digital solutions."
            : "Desarrollo web profesional: sitios a medida, aplicaciones PWA y soluciones digitales.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Buenos Aires",
            "addressCountry": "AR"
          },
          "sameAs": [
            "https://github.com/lauro-sa",
            "https://www.linkedin.com/in/laurosa/",
            "https://www.instagram.com/stianlauro/"
          ],
          "serviceType": [
            "Web Development",
            "Progressive Web Apps",
            "SEO Optimization",
            "Web Design"
          ],
          "areaServed": {
            "@type": "GeoCircle",
            "geoMidpoint": { "@type": "GeoCoordinates", "latitude": -34.6, "longitude": -58.38 },
            "geoRadius": "50000"
          },
          "priceRange": "$$"
        },
        {
          "@type": "Person",
          "name": "S7ian Code",
          "url": "https://stiancode.dev",
          "jobTitle": "Full-Stack Developer",
          "sameAs": [
            "https://github.com/lauro-sa",
            "https://www.linkedin.com/in/laurosa/"
          ]
        }
      ]
    })}
  </script>

  <!-- ============================================================
       Google Analytics (GA4) — REEMPLAZAR G-XXXXXXXXXX con tu ID
       Instrucciones: descomentar las 2 líneas y poner tu ID de GA4
       ============================================================ -->
