  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" onload="this.onload=null;this.rel='stylesheet'"/>
  <noscript><link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet"/></noscript>
</head>

<body>
  <slot/>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  // Detección automática de idioma del navegador
  (function() {
    const yaEligio = localStorage.getItem('sc-idioma');
    if (yaEligio) return;

    const enPaginaEs = !window.location.pathname.startsWith('/en');
    const navegadorEn = navigator.language.startsWith('en');

    if (enPaginaEs && navegadorEn) {
      localStorage.setItem('sc-idioma', 'en');
      window.location.replace('/en/');
      return;
    }
    localStorage.setItem('sc-idioma', document.documentElement.lang || 'es');
  })();
</script>

<script>
  import { iniciarToggleTema, iniciarMenuMobile, iniciarBarraProgreso, iniciarNavScroll, iniciarSmoothScroll, iniciarAnimacionIconos, iniciarTypewriter } from '../scripts/utilidades.js';
  import { iniciarParticulas } from '../scripts/particulas.js';

  document.addEventListener('DOMContentLoaded', () => {
    iniciarToggleTema('boton-tema-footer', 'sc-tema', ['boton-tema-mobile']);
    iniciarMenuMobile('boton-hamburguesa', 'menu-mobile');
    iniciarBarraProgreso('barra-progreso');
    iniciarNavScroll('nav-principal');
    iniciarSmoothScroll();
    iniciarAnimacionIconos('.tarjeta-servicio, .fila-proyecto');
    iniciarTypewriter();
    iniciarParticulas('canvas-particulas-hero');
    iniciarParticulas('canvas-particulas-contacto', {
      densidad: 8000,
      maximo: 60,
      escalaRadio: 0.6,
      opacidadLinea: 0.15,
      distanciaConexion: 120,
    });
  });

  // Animación del hero
  window.addEventListener('load', () => {
    const kf = document.createElement('style');
    kf.textContent = `
      @keyframes subirLinea { from { opacity:0; transform:translateY(100%); } to { opacity:1; transform:none; } }
      @keyframes slam {
        0%   { opacity:0; transform:scale(1.4) translateY(-18px); }
        50%  { opacity:1; transform:scale(.97) translateY(3px); }
        70%  { transform:scale(1.02) translateY(-1px); }
        85%  { transform:scale(.995) translateY(0); }
        100% { opacity:1; transform:scale(1) translateY(0); }
      }
      .linea-titulo { opacity: 0; }
    `;
    document.head.appendChild(kf);

    const badge = document.querySelector('.hero-badge');
    if (badge) { badge.style.transition = 'opacity .6s ease'; badge.style.opacity = '1'; }

    document.querySelectorAll('.linea-titulo').forEach((el, i) => {
      if (el.classList.contains('impacto')) {
        // Animación especial de impacto para "con impacto real"
        el.style.animation = `slam .65s ${0.2 + i * 0.13 + 0.15}s cubic-bezier(.22,.68,.36,1.2) forwards`;
      } else {
        el.style.animation = `subirLinea .85s ${0.2 + i * 0.13}s cubic-bezier(0.16,1,0.3,1) forwards`;
      }
    });

    setTimeout(() => {
      const sub  = document.querySelector('.hero-subtitulo');
      const btns = document.querySelector('.hero-botones');
      if (sub)  { sub.style.transition  = 'opacity .7s ease'; sub.style.opacity  = '1'; }
      if (btns) { btns.style.transition = 'opacity .7s ease'; btns.style.opacity = '1'; }
    }, 500);
  });
</script>
