---
// ============================================================
// SeccionServicios.astro — Grilla de servicios de stiancode.dev
// EDITAR: array SERVICIOS y objeto TEXTO abajo
// ============================================================
import IconoSVG from './ui/IconoSVG.astro';

interface Servicio {
  numero:      string;
  titulo:      string;
  descripcion: string;
  icono:       string;
}

// ---- Servicios ----
const SERVICIOS: Servicio[] = [
  {
    numero:      '01',
    titulo:      'Desarrollo web',
    descripcion: 'Sitios web a medida, responsivos y optimizados. Desde landings hasta plataformas completas, con foco en rendimiento y buena experiencia de uso.',
    icono:       'ventana',
  },
  {
    numero:      '02',
    titulo:      'Aplicaciones PWA',
    descripcion: 'Aplicaciones web progresivas que se sienten como nativas. Se instalan desde el navegador, funcionan offline y cargan rápido.',
    icono:       'celular',
  },
  {
    numero:      '03',
    titulo:      'Diseño web integral',
    descripcion: 'Diseño completo de interfaz y experiencia de usuario. Navegación clara, contenido bien organizado y un sitio que convierte visitas en clientes.',
    icono:       'estrella',
  },
  {
    numero:      '04',
    titulo:      'Diseño de componentes',
    descripcion: 'Componentes personalizados que se integran a tu sitio. Alineados con tu marca, pensados para ser reutilizables y fáciles de mantener.',
    icono:       'diamante',
  },
  {
    numero:      '05',
    titulo:      'Optimización SEO',
    descripcion: 'Mejoro tu posicionamiento en buscadores con SEO técnico, on-page, velocidad de carga y buenas prácticas de indexación.',
    icono:       'link',
  },
  {
    numero:      '06',
    titulo:      'Mantenimiento web',
    descripcion: 'Tu sitio siempre actualizado, seguro y funcionando. Actualizaciones, monitoreo y soporte técnico para que no tengas que preocuparte.',
    icono:       'escudo',
  },
  {
    numero:      '07',
    titulo:      'Alojamiento web',
    descripcion: 'Hosting seguro y confiable para que tu sitio esté disponible 24/7. Soluciones escalables que crecen con tu proyecto.',
    icono:       'edificio',
  },
  {
    numero:      '08',
    titulo:      'Optimización web',
    descripcion: 'Mejoro el rendimiento de tu sitio actual. Optimización de imágenes, código, tiempos de carga y experiencia general del usuario.',
    icono:       'rayo',
  },
];

const TEXTO = {
  etiqueta:  'Servicios',
  tituloN:   'Lo que hago.',
  tituloG:   'Cómo puedo ayudarte.',
  subtitulo: 'Desde sitios web hasta aplicaciones progresivas. Cada proyecto con atención al detalle y foco en resultados.',
};
---

<div class="fondo-puntos">
  <div class="panel-interior">
    <section class="seccion" id="servicios">

      <span class="etiqueta">{TEXTO.etiqueta}</span>
      <h2 class="titulo-dos-tonos">
        <span class="negro">{TEXTO.tituloN}</span><br>
        <span class="gris">{TEXTO.tituloG}</span>
      </h2>
      <p class="typewriter" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}></p>

      <div class="grilla-servicios" role="list">
        {SERVICIOS.map((serv) => (
          <div class="tarjeta-servicio" role="listitem">
            <div class="icono-contenedor serv-icono">
              <IconoSVG nombre={serv.icono} tamaño={22} grosor={1.5} />
            </div>
            <span class="serv-numero">{serv.numero}</span>
            <h3 class="serv-titulo">{serv.titulo}</h3>
            <p class="serv-texto">{serv.descripcion}</p>
          </div>
        ))}
      </div>

    </section>
  </div>
</div>

<style>
  .grilla-servicios { margin-top:52px;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--borde);border-radius:18px;overflow:hidden;transition:background .5s; }
  .tarjeta-servicio { background:var(--fondo);padding:32px 26px;display:flex;flex-direction:column;gap:14px;transition:background .2s; }
  .tarjeta-servicio:hover { background:var(--card); }
  .tarjeta-servicio:hover .serv-icono { transform:scale(1.1) rotate(-5deg); }
  .serv-icono   { transition:background .5s,transform .35s cubic-bezier(.34,1.56,.64,1); }
  .serv-numero  { font-size:12px;font-weight:600;color:var(--gris-titulo);letter-spacing:.05em;transition:color .5s; }
  .serv-titulo  { font-size:17px;font-weight:700;color:var(--texto);letter-spacing:-.2px;line-height:1.2;transition:color .5s; }
  .serv-texto   { font-size:13.5px;color:var(--gris-sub);line-height:1.65;transition:color .5s; }

  @media (max-width:1024px) { .grilla-servicios { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:600px)  { .grilla-servicios { grid-template-columns:1fr; } }
  @media (min-width:1025px) { .grilla-servicios { max-width:1200px; } }
</style>
