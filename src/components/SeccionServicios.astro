---
// ============================================================
// SeccionServicios.astro — Grilla de servicios de stiancode.dev
// ============================================================
import IconoSVG from './ui/IconoSVG.astro';
import { t } from '../i18n/utils.js';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

interface Servicio {
  numero:      string;
  titulo:      string;
  descripcion: string;
  icono:       string;
}

// ---- Servicios ----
const SERVICIOS: Servicio[] = [
  {
    numero:      '01',
    titulo:      t(lang, 'servicio_01_titulo'),
    descripcion: t(lang, 'servicio_01_desc'),
    icono:       'ventana',
  },
  {
    numero:      '02',
    titulo:      t(lang, 'servicio_02_titulo'),
    descripcion: t(lang, 'servicio_02_desc'),
    icono:       'celular',
  },
  {
    numero:      '03',
    titulo:      t(lang, 'servicio_03_titulo'),
    descripcion: t(lang, 'servicio_03_desc'),
    icono:       'estrella',
  },
  {
    numero:      '04',
    titulo:      t(lang, 'servicio_04_titulo'),
    descripcion: t(lang, 'servicio_04_desc'),
    icono:       'diamante',
  },
  {
    numero:      '05',
    titulo:      t(lang, 'servicio_05_titulo'),
    descripcion: t(lang, 'servicio_05_desc'),
    icono:       'link',
  },
  {
    numero:      '06',
    titulo:      t(lang, 'servicio_06_titulo'),
    descripcion: t(lang, 'servicio_06_desc'),
    icono:       'escudo',
  },
  {
    numero:      '07',
    titulo:      t(lang, 'servicio_07_titulo'),
    descripcion: t(lang, 'servicio_07_desc'),
    icono:       'edificio',
  },
  {
    numero:      '08',
    titulo:      t(lang, 'servicio_08_titulo'),
    descripcion: t(lang, 'servicio_08_desc'),
    icono:       'rayo',
  },
];

const TEXTO = {
  etiqueta:  t(lang, 'servicios_etiqueta'),
  tituloN:   t(lang, 'servicios_titulo_negro'),
  tituloG:   t(lang, 'servicios_titulo_gris'),
  subtitulo: t(lang, 'servicios_subtitulo'),
};
---

<div class="fondo-puntos">
  <div class="panel-interior">
    <section class="seccion" id="servicios">

      <span class="etiqueta">{TEXTO.etiqueta}</span>
      <h2 class="titulo-dos-tonos">
        <span class="negro">{TEXTO.tituloN}</span><br>
        <span class="gris">{TEXTO.tituloG}</span>
      </h2>
      <p class="typewriter" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}></p>

      <div class="grilla-servicios" role="list">
        {SERVICIOS.map((serv) => (
          <div class="tarjeta-servicio" role="listitem">
            <div class="icono-contenedor serv-icono">
              <IconoSVG nombre={serv.icono} tamaño={22} grosor={1.5} />
            </div>
            <span class="serv-numero">{serv.numero}</span>
            <h3 class="serv-titulo">{serv.titulo}</h3>
            <p class="serv-texto">{serv.descripcion}</p>
            <button
              class="serv-solicitar"
              data-abrir-modal="contacto"
              data-servicio-titulo={serv.titulo}
              data-servicio-desc={serv.descripcion}
            >{t(lang, 'servicios_boton_solicitar')}</button>
          </div>
        ))}
      </div>

    </section>
  </div>
</div>

<style>
  .grilla-servicios { margin-top:52px;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--borde);border-radius:0;overflow:visible;transition:background .5s;border:none;background:transparent; }
  .tarjeta-servicio { background:transparent;padding:32px 26px;display:flex;flex-direction:column;gap:14px;border-right:1px solid var(--borde);border-bottom:1px solid var(--borde);transition:background .2s,opacity .6s cubic-bezier(.22,1,.36,1),transform .6s cubic-bezier(.22,1,.36,1),border-color .5s;opacity:0;transform:translateY(24px); }
  .tarjeta-servicio:nth-child(4n) { border-right:none; }
  .tarjeta-servicio:nth-last-child(-n+4) { border-bottom:none; }
  .tarjeta-servicio.visible { opacity:1;transform:translateY(0); }
  .tarjeta-servicio:hover { background:color-mix(in srgb, var(--card) 50%, transparent); }
  .tarjeta-servicio:hover .serv-icono { transform:scale(1.1) rotate(-5deg); }
  .serv-icono   { transition:background .5s,transform .35s cubic-bezier(.34,1.56,.64,1); }
  .serv-numero  { font-size:12px;font-weight:600;color:var(--gris-titulo);letter-spacing:.05em;transition:color .5s; }
  .serv-titulo  { font-size:17px;font-weight:700;color:var(--texto);letter-spacing:-.2px;line-height:1.2;transition:color .5s; }
  .serv-texto   { font-size:13.5px;color:var(--gris-sub);line-height:1.65;transition:color .5s; }

  .serv-solicitar { margin-top:auto;padding:0;background:none;border:none;font-family:var(--fuente-principal);font-size:13px;font-weight:600;color:var(--acento);cursor:pointer;text-align:left;transition:color .2s; }
  .serv-solicitar:hover { color:var(--texto); }

  @media (max-width:1024px) {
    .grilla-servicios { grid-template-columns:repeat(2,1fr); }
    .tarjeta-servicio { border-right:none;border-bottom:1px solid var(--borde); }
    .tarjeta-servicio:nth-child(odd) { border-right:1px solid var(--borde); }
    .tarjeta-servicio:nth-last-child(-n+2) { border-bottom:none; }
    .tarjeta-servicio:nth-last-child(1):nth-child(odd) { border-bottom:none; }
  }
  @media (max-width:600px) {
    .grilla-servicios { grid-template-columns:1fr; }
    .tarjeta-servicio { border-right:none !important;border-bottom:1px solid var(--borde); }
    .tarjeta-servicio:last-child { border-bottom:none; }
  }
  @media (min-width:1025px) { .grilla-servicios { max-width:1200px; } }
</style>

<script>
  const tarjetas = document.querySelectorAll('.tarjeta-servicio');
  const servObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const all = Array.from(tarjetas);
      const idx = all.indexOf(entry.target as HTMLElement);
      setTimeout(() => entry.target.classList.add('visible'), idx * 100);
      servObserver.unobserve(entry.target);
    });
  }, { threshold: 0.15 });
  tarjetas.forEach((t) => servObserver.observe(t));
</script>
