---
import Boton from './Boton.astro';
import { t } from '../i18n/utils.js';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

const TEXTO = {
  etiqueta:  t(lang, 'noticias_etiqueta'),
  tituloN:   t(lang, 'noticias_titulo_negro'),
  tituloG:   t(lang, 'noticias_titulo_gris'),
  subtitulo: t(lang, 'noticias_subtitulo'),
};

// Preview de categorías que se encuentran en Pulso Tech
const CATEGORIAS = [
  { nombre: 'Tech',    color: '#7c5ce8' },
  { nombre: 'Apple',   color: '#60b0e0' },
  { nombre: 'Android', color: '#10b981' },
  { nombre: 'Dev',     color: '#f97316' },
  { nombre: 'Mobile',  color: '#3b82f6' },
];

// Enlace según idioma
const enlaceNoticias = lang === 'en' ? '/en/news' : '/novedades';

// Titulares de ejemplo (se ven en el home como preview)
const TITULARES = [
  { titulo: t(lang, 'noticias_titular_01'), tag: 'Tech' },
  { titulo: t(lang, 'noticias_titular_02'), tag: 'Apple' },
  { titulo: t(lang, 'noticias_titular_03'), tag: 'Android' },
];
---

<div class="fondo-puntos fondo-puntos-visible">
    <section class="seccion" id="noticias">

      <span class="etiqueta">{TEXTO.etiqueta}</span>
      <h2 class="titulo-dos-tonos">
        <span class="negro">{TEXTO.tituloN}</span><br>
        <span class="gris">{TEXTO.tituloG}</span>
      </h2>
      <p class="typewriter" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}></p>

      <!-- Categorías como pills -->
      <div class="pt-categorias">
        {CATEGORIAS.map((c) => (
          <a class="pt-cat" href={enlaceNoticias} style={`--cat-color: ${c.color}`}>
            <span class="pt-cat-dot"></span>
            {c.nombre}
          </a>
        ))}
      </div>

      <!-- Preview de titulares -->
      <div class="pt-titulares">
        {TITULARES.map((item) => (
          <a class="pt-titular" href={enlaceNoticias}>
            <span class="pt-titular-tag">{item.tag}</span>
            <span class="pt-titular-texto">{item.titulo}</span>
            <span class="pt-titular-flecha">→</span>
          </a>
        ))}
      </div>

      <div class="pt-ver">
        <Boton variante="fantasma" href={enlaceNoticias}>
          {t(lang, 'noticias_boton')}
        </Boton>
      </div>

    </section>
</div>

<style>
  /* Categorías */
  .pt-categorias {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pt-cat {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--gris-sub);
    background: var(--card);
    border: 1px solid var(--borde);
    padding: 6px 14px;
    border-radius: var(--radio-pill);
    text-decoration: none;
    transition: background 0.2s, border-color 0.25s, color 0.2s, transform 0.2s;
  }

  .pt-cat:hover {
    border-color: var(--cat-color);
    color: var(--texto);
    transform: translateY(-1px);
  }

  .pt-cat-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cat-color);
    flex-shrink: 0;
  }

  /* Titulares */
  .pt-titulares {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
  }

  .pt-titular {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 4px;
    border-bottom: 1px solid var(--borde);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, border-color var(--transicion);
  }

  .pt-titular:last-child { border-bottom: none; }

  .pt-titular:hover {
    background: var(--card);
    margin: 0 -12px;
    padding-left: 16px;
    padding-right: 16px;
    border-radius: 10px;
  }

  .pt-titular-tag {
    font-size: 10px;
    font-weight: 600;
    color: var(--acento);
    background: var(--ghost-fondo);
    padding: 2px 8px;
    border-radius: var(--radio-pill);
    border: 1px solid var(--borde);
    text-transform: uppercase;
    letter-spacing: 0.3px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background var(--transicion), color var(--transicion), border-color var(--transicion);
  }

  .pt-titular-texto {
    font-size: 14px;
    font-weight: 600;
    color: var(--texto);
    flex: 1;
    line-height: 1.4;
    transition: color 0.3s;
  }

  .pt-titular:hover .pt-titular-texto { color: var(--acento); }

  .pt-titular-flecha {
    font-size: 14px;
    color: var(--gris-titulo);
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }

  .pt-titular:hover .pt-titular-flecha {
    color: var(--acento);
    transform: translateX(3px);
  }

  /* Ver más */
  .pt-ver { margin-top: 28px; }

  @media (max-width: 600px) {
    .pt-categorias { gap: 6px; }
    .pt-cat { font-size: 11px; padding: 5px 12px; }
    .pt-titular-texto { font-size: 13px; }
  }
</style>
