---
// ============================================================
// AgendarMeet.astro — Modal para agendar videollamada
//
// Disponibilidad: Lunes y Miércoles de 12:00 a 20:00
// Se abre como modal desde un botón/tarjeta en la página.
// ============================================================
import IconoSVG from './ui/IconoSVG.astro';
import { t } from '../i18n/utils.js';
import { CONTACTO, WEB3FORMS_KEY } from '../config.js';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

// Traducciones que necesita el script del lado cliente
const i18nData = JSON.stringify({
  email: CONTACTO.email,
  web3formsKey: WEB3FORMS_KEY,
  meses: t(lang, 'agendar_meses').split(','),
  diasSemana: t(lang, 'agendar_dias_semana').split(','),
  pasoIndicador: t(lang, 'agendar_paso_indicador'),
  fechaConector: t(lang, 'agendar_fecha_conector'),
  reunion: t(lang, 'agendar_reunion'),
  hs: t(lang, 'agendar_hs'),
  pendiente: t(lang, 'agendar_pendiente'),
  agendadoDesde: t(lang, 'agendar_agendado_desde'),
});
---

<!-- Tarjeta trigger — se muestra en la página -->
<button type="button" class="agendar-trigger" id="agendarTrigger">
  <div class="agendar-trigger-izq">
    <div class="icono-contenedor agendar-trigger-icono agendar-animable">
      <IconoSVG nombre="calendario" tamaño={20} grosor={1.5} />
    </div>
    <div>
      <span class="agendar-trigger-titulo">{t(lang, 'agendar_trigger_titulo')}</span>
      <span class="agendar-trigger-sub">{t(lang, 'agendar_trigger_sub')}</span>
    </div>
  </div>
  <svg class="agendar-trigger-flecha" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
</button>

<!-- Modal -->
<div class="agendar-overlay" id="agendarModal" aria-hidden="true" role="dialog" aria-modal="true" aria-label={t(lang, 'agendar_modal_titulo')} data-i18n={i18nData}>
  <div class="agendar-modal">

    <!-- Cabecera -->
    <div class="agendar-modal-cabecera">
      <div class="agendar-modal-titulo-row">
        <div class="icono-contenedor agendar-modal-icono">
          <IconoSVG nombre="calendario" tamaño={20} grosor={1.5} />
        </div>
        <h3 class="agendar-modal-titulo">{t(lang, 'agendar_modal_titulo')}</h3>
      </div>
      <button class="agendar-modal-cerrar" aria-label={t(lang, 'agendar_modal_cerrar')} type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Barra de progreso -->
    <div class="agendar-progreso">
      <div class="agendar-progreso-barra" id="agendarProgreso" style="width: 25%"></div>
    </div>
    <span class="agendar-paso-indicador" id="agendarPasoIndicador">{t(lang, 'agendar_paso_indicador').replace('{n}', '1')}</span>

    <!-- Paso 1: Datos -->
    <div class="agendar-vista" id="agendarVistaDatos">
      <p class="agendar-vista-titulo">{t(lang, 'agendar_paso1_titulo')}</p>
      <div class="agendar-campo">
        <label for="agendar-nombre">{t(lang, 'agendar_campo_nombre')}</label>
        <input type="text" id="agendar-nombre" placeholder={t(lang, 'agendar_campo_nombre_ph')} required autocomplete="name" />
      </div>
      <div class="agendar-campo">
        <label for="agendar-email">{t(lang, 'agendar_campo_email')}</label>
        <input type="email" id="agendar-email" placeholder={t(lang, 'agendar_campo_email_ph')} required autocomplete="email" />
      </div>
      <div class="agendar-nav-btns">
        <span></span>
        <button type="button" class="boton-oscuro agendar-btn-sm" id="agendarDatosSiguiente">
          {t(lang, 'agendar_btn_siguiente')}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    <!-- Paso 2: Calendario -->
    <div class="agendar-vista" id="agendarVistaCalendario" style="display:none">
      <p class="agendar-vista-titulo">{t(lang, 'agendar_paso2_titulo')}</p>
      <div class="agendar-mes-nav">
        <button type="button" class="agendar-nav-btn" id="agendarMesAnterior" aria-label={t(lang, 'agendar_mes_anterior')}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <span class="agendar-mes-titulo" id="agendarMesTitulo"></span>
        <button type="button" class="agendar-nav-btn" id="agendarMesSiguiente" aria-label={t(lang, 'agendar_mes_siguiente')}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <div class="agendar-dias-semana">
        {t(lang, 'agendar_dias_abrev').split(',').map((dia, i) => (
          <span class={i >= 5 ? 'agendar-finde' : ''}>{dia}</span>
        ))}
      </div>
      <div class="agendar-grilla" id="agendarGrilla"></div>

      <div class="agendar-leyenda">
        <span class="agendar-leyenda-item"><span class="agendar-leyenda-punto agendar-leyenda-disponible"></span> {t(lang, 'agendar_disponible')}</span>
        <span class="agendar-leyenda-item"><span class="agendar-leyenda-punto agendar-leyenda-no"></span> {t(lang, 'agendar_no_disponible')}</span>
      </div>

      <div class="agendar-nav-btns">
        <button type="button" class="boton-fantasma agendar-btn-sm" id="agendarCalendarioAtras">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          {t(lang, 'agendar_btn_atras')}
        </button>
        <span></span>
      </div>
    </div>

    <!-- Paso 3: Horarios -->
    <div class="agendar-vista" id="agendarVistaHorarios" style="display:none">
      <div class="agendar-fecha-elegida">
        <span id="agendarFechaTexto"></span>
        <button type="button" class="agendar-link-btn" id="agendarCambiarFecha">{t(lang, 'agendar_cambiar_fecha')}</button>
      </div>
      <p class="agendar-horarios-label">{t(lang, 'agendar_elegir_horario')}</p>
      <div class="agendar-slots" id="agendarSlots"></div>

      <div class="agendar-nav-btns">
        <button type="button" class="boton-fantasma agendar-btn-sm" id="agendarHorariosAtras">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          {t(lang, 'agendar_btn_atras')}
        </button>
        <span></span>
      </div>
    </div>

    <!-- Paso 4: Confirmación -->
    <div class="agendar-vista" id="agendarVistaConfirmar" style="display:none">
      <div class="agendar-confirmar-resumen">
        <div class="agendar-confirmar-icono agendar-animable">
          <div class="icono-contenedor" style="width:56px;height:56px">
            <IconoSVG nombre="check" tamaño={28} grosor={2} />
          </div>
        </div>
        <p class="agendar-confirmar-fecha" id="agendarResumenTexto"></p>
        <p class="agendar-confirmar-nota">{t(lang, 'agendar_confirmar_nota')}</p>
      </div>
      <div class="agendar-confirmar-btns">
        <button type="button" class="boton-fantasma agendar-btn-sm" id="agendarVolver">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          {t(lang, 'agendar_btn_volver')}
        </button>
        <button type="button" class="boton-oscuro agendar-btn-sm" id="agendarEnviar">
          {t(lang, 'agendar_btn_enviar')}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    <!-- Paso 5: Éxito -->
    <div class="agendar-vista" id="agendarVistaExito" style="display:none">
      <div class="agendar-confirmar-resumen">
        <div class="agendar-confirmar-icono agendar-animable">
          <div class="icono-contenedor" style="width:56px;height:56px">
            <IconoSVG nombre="correo" tamaño={28} grosor={2} />
          </div>
        </div>
        <p class="agendar-confirmar-fecha">{t(lang, 'agendar_exito_titulo')}</p>
        <p class="agendar-confirmar-nota">{t(lang, 'agendar_exito_nota')}</p>
      </div>
      <div class="agendar-confirmar-btns" style="justify-content:center">
        <button type="button" class="boton-oscuro agendar-btn-sm" id="agendarCerrarExito">{t(lang, 'agendar_btn_cerrar')}</button>
      </div>
    </div>

  </div>
</div>

<style>
  /* ===== Trigger (tarjeta que abre el modal) ===== */
  .agendar-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 18px 20px;
    background: var(--card);
    border: 1px solid var(--borde);
    border-radius: var(--radio-card);
    cursor: pointer;
    font-family: var(--fuente-principal);
    text-align: left;
    margin-bottom: 20px;
    transition: border-color 0.2s, transform 0.2s, background var(--transicion);
  }
  .agendar-trigger:hover {
    border-color: var(--acento);
    transform: translateY(-2px);
  }
  .agendar-trigger-izq {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .agendar-trigger-icono {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }
  .agendar-trigger-titulo {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--texto);
    transition: color var(--transicion);
  }
  .agendar-trigger-sub {
    display: block;
    font-size: 12px;
    color: var(--gris-sub);
    margin-top: 2px;
    transition: color var(--transicion);
  }
  .agendar-trigger-flecha {
    color: var(--gris-sub);
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .agendar-trigger:hover .agendar-trigger-flecha {
    color: var(--acento);
    transform: translateX(3px);
  }

  /* ===== Overlay ===== */
  .agendar-overlay {
    position: fixed;
    inset: 0;
    z-index: 990;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .agendar-overlay.abierto {
    opacity: 1;
    visibility: visible;
  }

  /* ===== Modal ===== */
  .agendar-modal {
    background: var(--fondo);
    border: 1px solid var(--borde);
    border-radius: var(--radio-card);
    width: 100%;
    max-width: 420px;
    padding: 28px;
    position: relative;
    z-index: 2;
    transform: translateY(20px) scale(0.97);
    transition: transform 0.3s ease, background var(--transicion), border-color var(--transicion);
  }
  .agendar-overlay.abierto .agendar-modal {
    transform: translateY(0) scale(1);
  }

  /* Cabecera */
  .agendar-modal-cabecera {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .agendar-modal-titulo-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .agendar-modal-icono {
    width: 36px;
    height: 36px;
  }
  .agendar-modal-titulo {
    font-size: 18px;
    font-weight: 600;
    color: var(--texto);
    transition: color var(--transicion);
  }
  .agendar-modal-cerrar {
    background: none;
    border: none;
    color: var(--gris-sub);
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, background 0.2s;
  }
  .agendar-modal-cerrar:hover {
    color: var(--texto);
    background: var(--ghost-fondo);
  }
  /* Barra de progreso */
  .agendar-progreso {
    height: 4px;
    background: var(--ghost-fondo);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 6px;
  }
  .agendar-progreso-barra {
    height: 100%;
    background: var(--gradiente);
    border-radius: 4px;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .agendar-paso-indicador {
    font-size: 11px;
    color: var(--gris-sub);
    margin-bottom: 18px;
    display: block;
  }

  /* Campos de datos */
  .agendar-campo { margin-bottom: 16px; }
  .agendar-campo label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--texto);
    margin-bottom: 6px;
    transition: color var(--transicion);
  }
  .agendar-campo input {
    width: 100%;
    padding: 12px 14px;
    font-size: 15px;
    font-family: var(--fuente-principal);
    color: var(--texto);
    background: var(--fondo-alt);
    border: 1px solid var(--borde);
    border-radius: 10px;
    outline: none;
    transition: border-color 0.2s, background var(--transicion), color var(--transicion);
  }
  .agendar-campo input:focus { border-color: var(--acento); }
  .agendar-campo input::placeholder { color: var(--gris-titulo); }
  .agendar-campo.error input { border-color: #e74c3c; }

  .agendar-vista-titulo {
    font-size: 15px;
    font-weight: 500;
    color: var(--gris-sub);
    margin-bottom: 18px;
    transition: color var(--transicion);
  }

  /* Navegación dentro de cada paso */
  .agendar-nav-btns {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--borde);
  }

  /* ===== Vistas ===== */
  .agendar-vista { animation: agendarFade 0.3s ease; }
  @keyframes agendarFade {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ===== Navegación de mes ===== */
  .agendar-mes-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .agendar-mes-titulo {
    font-size: 15px;
    font-weight: 600;
    color: var(--texto);
    transition: color var(--transicion);
  }
  .agendar-nav-btn {
    background: var(--ghost-fondo);
    border: 1px solid var(--borde);
    color: var(--gris-sub);
    cursor: pointer;
    padding: 7px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, background 0.2s, border-color var(--transicion);
  }
  .agendar-nav-btn:hover { color: var(--texto); background: var(--fondo-alt); }
  .agendar-nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  /* ===== Días de la semana ===== */
  .agendar-dias-semana {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    margin-bottom: 4px;
  }
  .agendar-dias-semana span {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--gris-titulo);
    padding: 6px 0;
    transition: color var(--transicion);
  }
  .agendar-finde { opacity: 0.4; }

  /* Grilla contenedor (scoped OK porque está en el HTML) */
  .agendar-grilla {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }

  /* Leyenda */
  .agendar-leyenda {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--borde);
  }
  .agendar-leyenda-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--gris-sub);
  }
  .agendar-leyenda-punto {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .agendar-leyenda-disponible { background: var(--acento); }
  .agendar-leyenda-no { background: var(--gris-titulo); opacity: 0.35; }

  /* ===== Horarios ===== */
  .agendar-fecha-elegida {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding: 14px 18px;
    background: color-mix(in srgb, var(--acento) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--acento) 20%, transparent);
    border-radius: 12px;
  }
  .agendar-fecha-elegida span {
    font-size: 15px;
    font-weight: 600;
    color: var(--texto);
    transition: color var(--transicion);
  }
  .agendar-link-btn {
    background: none;
    border: none;
    color: var(--acento);
    font-size: 13px;
    font-weight: 500;
    font-family: var(--fuente-principal);
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .agendar-link-btn:hover { opacity: 0.7; }

  .agendar-horarios-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--gris-sub);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color var(--transicion);
  }

  .agendar-slots {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  /* ===== Confirmación ===== */
  .agendar-confirmar-resumen {
    text-align: center;
    padding: 32px 10px;
  }
  .agendar-confirmar-icono {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .agendar-confirmar-fecha {
    font-size: 18px;
    font-weight: 600;
    color: var(--texto);
    line-height: 1.6;
    margin-bottom: 10px;
    transition: color var(--transicion);
  }
  .agendar-confirmar-nota {
    font-size: 13px;
    color: var(--gris-sub);
    line-height: 1.5;
    transition: color var(--transicion);
  }
  .agendar-confirmar-btns {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 18px;
    border-top: 1px solid var(--borde);
  }
  .agendar-btn-sm {
    padding: 10px 20px;
    font-size: 14px;
  }

  /* ===== Responsive ===== */
  @media (max-width: 480px) {
    .agendar-modal { padding: 22px 18px; }
    .agendar-slots { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('agendarModal');
    const trigger = document.getElementById('agendarTrigger');
    const grilla = document.getElementById('agendarGrilla');
    const mesTitulo = document.getElementById('agendarMesTitulo');
    const btnMesAnterior = document.getElementById('agendarMesAnterior');
    const btnMesSiguiente = document.getElementById('agendarMesSiguiente');
    const vistaDatos = document.getElementById('agendarVistaDatos');
    const vistaCalendario = document.getElementById('agendarVistaCalendario');
    const vistaHorarios = document.getElementById('agendarVistaHorarios');
    const vistaConfirmar = document.getElementById('agendarVistaConfirmar');
    const vistaExito = document.getElementById('agendarVistaExito');
    const slotsContainer = document.getElementById('agendarSlots');
    const fechaTexto = document.getElementById('agendarFechaTexto');
    const resumenTexto = document.getElementById('agendarResumenTexto');
    const barraProgreso = document.getElementById('agendarProgreso');
    const pasoIndicador = document.getElementById('agendarPasoIndicador');
    const inputNombre = document.getElementById('agendar-nombre');
    const inputEmail = document.getElementById('agendar-email');

    if (!modal || !grilla) return;

    // Leer traducciones del data attribute
    const i18n = JSON.parse(modal.dataset.i18n || '{}');
    const MESES = i18n.meses || ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
    const DIAS_SEMANA = i18n.diasSemana || ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
    const pasoTemplate = i18n.pasoIndicador || 'Paso {n} de 4';
    const fechaConector = i18n.fechaConector || 'de';
    const txtReunion = i18n.reunion || 'Reunión';
    const txtHs = i18n.hs || 'hs';
    const txtPendiente = i18n.pendiente || 'Pendiente de confirmación';
    const txtAgendadoDesde = i18n.agendadoDesde || 'Agendado desde';

    const todas = [vistaDatos, vistaCalendario, vistaHorarios, vistaConfirmar, vistaExito];
    const hoy = new Date();
    let mesActual = hoy.getMonth();
    let anioActual = hoy.getFullYear();
    let fechaSeleccionada = null;
    let horaSeleccionada = null;
    let pasoActual = 1;

    const DIAS_DISPONIBLES = [1, 3];
    const HORARIOS = [];
    for (let h = 12; h < 20; h++) {
      HORARIOS.push(`${h.toString().padStart(2, '0')}:00`);
    }

    function actualizarProgreso(paso) {
      pasoActual = paso;
      const porcentaje = (paso / 4) * 100;
      barraProgreso.style.width = `${porcentaje}%`;
      pasoIndicador.textContent = paso <= 4 ? pasoTemplate.replace('{n}', paso) : '';
      if (paso > 4) pasoIndicador.style.display = 'none';
      else pasoIndicador.style.display = '';
    }

    function mostrarVista(vista, paso) {
      todas.forEach(v => { if (v) v.style.display = 'none'; });
      if (vista) vista.style.display = 'block';
      if (paso) actualizarProgreso(paso);
    }

    // Abrir/cerrar modal
    function abrirModal() {
      modal.classList.add('abierto');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      fechaSeleccionada = null;
      horaSeleccionada = null;
      mostrarVista(vistaDatos, 1);
    }

    function cerrarModal() {
      modal.classList.remove('abierto');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    trigger.addEventListener('click', abrirModal);
    modal.querySelector('.agendar-modal-cerrar').addEventListener('click', cerrarModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) cerrarModal(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('abierto')) cerrarModal();
    });

    // Paso 1 → 2: Validar datos
    document.getElementById('agendarDatosSiguiente').addEventListener('click', () => {
      let valido = true;
      document.querySelectorAll('#agendarModal .agendar-campo.error').forEach(c => c.classList.remove('error'));

      if (!inputNombre.value.trim()) {
        inputNombre.closest('.agendar-campo').classList.add('error');
        valido = false;
      }
      if (!inputEmail.value.trim() || !inputEmail.validity.valid) {
        inputEmail.closest('.agendar-campo').classList.add('error');
        valido = false;
      }
      if (!valido) return;

      mostrarVista(vistaCalendario, 2);
      renderizarMes();
    });

    // Paso 2 ← atrás
    document.getElementById('agendarCalendarioAtras').addEventListener('click', () => {
      mostrarVista(vistaDatos, 1);
    });

    // Paso 3 ← atrás
    document.getElementById('agendarHorariosAtras').addEventListener('click', () => {
      mostrarVista(vistaCalendario, 2);
    });

    // Cambiar fecha desde horarios
    document.getElementById('agendarCambiarFecha').addEventListener('click', () => {
      mostrarVista(vistaCalendario, 2);
    });

    // Paso 4 ← volver
    document.getElementById('agendarVolver').addEventListener('click', () => {
      mostrarVista(vistaHorarios, 3);
    });

    // Navegación meses
    btnMesAnterior.addEventListener('click', () => {
      mesActual--;
      if (mesActual < 0) { mesActual = 11; anioActual--; }
      renderizarMes();
    });
    btnMesSiguiente.addEventListener('click', () => {
      mesActual++;
      if (mesActual > 11) { mesActual = 0; anioActual++; }
      renderizarMes();
    });

    function esDisponible(fecha) {
      if (fecha < new Date(hoy.getFullYear(), hoy.getMonth(), hoy.getDate())) return false;
      return DIAS_DISPONIBLES.includes(fecha.getDay());
    }

    function renderizarMes() {
      grilla.innerHTML = '';
      mesTitulo.textContent = `${MESES[mesActual]} ${anioActual}`;
      btnMesAnterior.disabled = mesActual === hoy.getMonth() && anioActual === hoy.getFullYear();

      const primerDia = new Date(anioActual, mesActual, 1);
      let inicioCol = primerDia.getDay() - 1;
      if (inicioCol < 0) inicioCol = 6;
      const diasEnMes = new Date(anioActual, mesActual + 1, 0).getDate();

      for (let i = 0; i < inicioCol; i++) {
        const vacio = document.createElement('button');
        vacio.className = 'agendar-dia agendar-dia-vacio';
        vacio.disabled = true;
        grilla.appendChild(vacio);
      }

      for (let d = 1; d <= diasEnMes; d++) {
        const fecha = new Date(anioActual, mesActual, d);
        const btn = document.createElement('button');
        btn.className = 'agendar-dia';
        btn.textContent = d;
        btn.type = 'button';

        const esPasado = fecha < new Date(hoy.getFullYear(), hoy.getMonth(), hoy.getDate());
        const esHoy = d === hoy.getDate() && mesActual === hoy.getMonth() && anioActual === hoy.getFullYear();
        const esFinde = fecha.getDay() === 0 || fecha.getDay() === 6;

        if (esHoy) btn.classList.add('agendar-dia-hoy');

        if (esFinde) {
          btn.classList.add('agendar-dia-finde');
          btn.disabled = true;
        } else if (esPasado) {
          btn.classList.add('agendar-dia-pasado');
          btn.disabled = true;
        } else if (esDisponible(fecha)) {
          btn.classList.add('agendar-dia-disponible');
          btn.addEventListener('click', () => seleccionarDia(fecha));
        } else {
          btn.disabled = true;
          btn.classList.add('agendar-dia-pasado');
        }

        grilla.appendChild(btn);
      }
    }

    function seleccionarDia(fecha) {
      fechaSeleccionada = fecha;
      horaSeleccionada = null;

      const diaNombre = DIAS_SEMANA[fecha.getDay()];
      const diaNum = fecha.getDate();
      const mesNombre = MESES[fecha.getMonth()];
      fechaTexto.textContent = fechaConector ? `${diaNombre} ${diaNum} ${fechaConector} ${mesNombre}` : `${diaNombre} ${mesNombre} ${diaNum}`;

      slotsContainer.innerHTML = '';
      HORARIOS.forEach(hora => {
        const slot = document.createElement('button');
        slot.className = 'agendar-slot';
        slot.textContent = hora;
        slot.type = 'button';
        slot.addEventListener('click', () => seleccionarHora(hora, slot));
        slotsContainer.appendChild(slot);
      });

      mostrarVista(vistaHorarios, 3);
    }

    function seleccionarHora(hora, btn) {
      horaSeleccionada = hora;
      slotsContainer.querySelectorAll('.agendar-slot-seleccionado').forEach(el => el.classList.remove('agendar-slot-seleccionado'));
      btn.classList.add('agendar-slot-seleccionado');

      const diaNombre = DIAS_SEMANA[fechaSeleccionada.getDay()];
      const diaNum = fechaSeleccionada.getDate();
      const mesNombre = MESES[fechaSeleccionada.getMonth()];
      const horaFin = `${(parseInt(hora) + 1).toString().padStart(2, '0')}:00`;
      resumenTexto.innerHTML = fechaConector
        ? `${diaNombre} ${diaNum} ${fechaConector} ${mesNombre}<br>${hora} — ${horaFin}${txtHs ? ' ' + txtHs : ''}`
        : `${diaNombre} ${mesNombre} ${diaNum}<br>${hora} — ${horaFin}${txtHs ? ' ' + txtHs : ''}`;

      mostrarVista(vistaConfirmar, 4);

      const animable = vistaConfirmar.querySelector('.agendar-animable');
      if (animable) {
        animable.classList.remove('dibujado');
        setTimeout(() => animable.classList.add('dibujado'), 150);
      }
    }

    // Confirmar → enviar email y mostrar éxito
    document.getElementById('agendarEnviar').addEventListener('click', async () => {
      if (!fechaSeleccionada || !horaSeleccionada) return;

      const nombre = inputNombre.value.trim();
      const email = inputEmail.value.trim();
      const diaNombre = DIAS_SEMANA[fechaSeleccionada.getDay()];
      const diaNum = fechaSeleccionada.getDate();
      const mesNombre = MESES[fechaSeleccionada.getMonth()];
      const anio = fechaSeleccionada.getFullYear();
      const horaFin = `${(parseInt(horaSeleccionada) + 1).toString().padStart(2, '0')}:00`;

      const fechaFormateada = fechaConector
        ? `${diaNombre} ${diaNum} ${fechaConector} ${mesNombre}`
        : `${diaNombre} ${mesNombre} ${diaNum}`;
      const asunto = `${txtReunion} — ${fechaFormateada}, ${horaSeleccionada}${txtHs ? txtHs : ''} — ${nombre}`;
      const cuerpo = `${txtReunion}:\n\nNOMBRE: ${nombre}\nEMAIL: ${email}\n\nFECHA: ${fechaFormateada} ${fechaConector ? fechaConector + ' ' : ''}${anio}\nHORARIO: ${horaSeleccionada} — ${horaFin}${txtHs ? ' ' + txtHs : ''}\n\n${txtPendiente}.\n\n---\n${txtAgendadoDesde} stiancode.dev/contacto`;

      // Enviar via Web3Forms
      const formData = new FormData();
      formData.append('access_key', i18n.web3formsKey);
      formData.append('subject', asunto);
      formData.append('from_name', nombre);
      formData.append('email', email);
      formData.append('message', cuerpo);

      try {
        const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
        const data = await res.json();

        if (data.success) {
          mostrarVista(vistaExito, 5);
          lanzarConfetti();
          const animable = vistaExito.querySelector('.agendar-animable');
          if (animable) {
            animable.classList.remove('dibujado');
            setTimeout(() => animable.classList.add('dibujado'), 150);
          }
        } else {
          window.open(`mailto:${i18n.email || ''}?subject=${encodeURIComponent(asunto)}&body=${encodeURIComponent(cuerpo)}`, '_blank');
        }
      } catch {
        window.open(`mailto:${i18n.email || ''}?subject=${encodeURIComponent(asunto)}&body=${encodeURIComponent(cuerpo)}`, '_blank');
      }
    });

    // Cerrar desde éxito
    document.getElementById('agendarCerrarExito').addEventListener('click', () => {
      cerrarModal();
      // Reset
      setTimeout(() => {
        inputNombre.value = '';
        inputEmail.value = '';
        fechaSeleccionada = null;
        horaSeleccionada = null;
      }, 300);
    });

    // Confetti festivo — lluvia desde arriba, detrás del modal
    function lanzarConfetti() {
      const canvas = document.createElement('canvas');
      canvas.style.cssText = 'position:fixed;inset:0;z-index:1;pointer-events:none';
      modal.appendChild(canvas);
      const ctx = canvas.getContext('2d');
      const W = canvas.width = window.innerWidth;
      const H = canvas.height = window.innerHeight;

      const COLORES = ['#8964e8','#a78bfa','#4c9cd0','#60b0e0','#c4b5fd','#7dd3fc','#e0d4ff','#bae6fd'];
      const piezas = [];
      const TOTAL = 100;

      for (let i = 0; i < TOTAL; i++) {
        // Nacen arriba, distribuidas a lo ancho, con delay escalonado
        const tipo = Math.random();
        piezas.push({
          x: Math.random() * W,
          y: -20 - Math.random() * H * 0.5,
          vx: (Math.random() - 0.5) * 1.5,
          vy: Math.random() * 1.5 + 1,
          // Formas variadas: cuadrados, rectángulos, círculos
          forma: tipo < 0.33 ? 'rect' : tipo < 0.66 ? 'circle' : 'strip',
          tamaño: Math.random() * 6 + 3,
          color: COLORES[Math.floor(Math.random() * COLORES.length)],
          rotacion: Math.random() * 360,
          rotVel: (Math.random() - 0.5) * 4,
          opacidad: 0.8 + Math.random() * 0.2,
          gravedad: 0.02 + Math.random() * 0.02,
          balanceo: Math.random() * Math.PI * 2,
          balanceoAmp: 0.3 + Math.random() * 0.5,
          balanceoVel: 0.015 + Math.random() * 0.025,
          delay: Math.random() * 40,
        });
      }

      let frame = 0;
      function animar() {
        ctx.clearRect(0, 0, W, H);
        let activas = 0;

        piezas.forEach(p => {
          if (p.opacidad <= 0) return;
          if (frame < p.delay) { activas++; return; }

          activas++;
          p.balanceo += p.balanceoVel;
          p.x += p.vx + Math.sin(p.balanceo) * p.balanceoAmp;
          p.y += p.vy;
          p.vy += p.gravedad;
          p.rotacion += p.rotVel;

          // Fade cuando pasa el modal
          if (p.y > H * 0.85) p.opacidad -= 0.03;

          ctx.save();
          ctx.translate(p.x, p.y);
          ctx.rotate(p.rotacion * Math.PI / 180);
          ctx.globalAlpha = Math.max(0, p.opacidad);
          ctx.fillStyle = p.color;

          if (p.forma === 'circle') {
            ctx.beginPath();
            ctx.arc(0, 0, p.tamaño / 2, 0, Math.PI * 2);
            ctx.fill();
          } else if (p.forma === 'strip') {
            ctx.fillRect(-p.tamaño / 2, -1, p.tamaño, 2.5);
          } else {
            ctx.fillRect(-p.tamaño / 2, -p.tamaño / 2, p.tamaño, p.tamaño * 0.6);
          }

          ctx.restore();
        });

        frame++;
        if (activas > 0 && frame < 400) {
          requestAnimationFrame(animar);
        } else {
          canvas.remove();
        }
      }
      requestAnimationFrame(animar);
    }

    // Animar ícono del trigger
    const triggerAnimable = trigger.querySelector('.agendar-animable');
    if (triggerAnimable) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('dibujado'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.3 });
      obs.observe(triggerAnimable);
    }
  });
</script>

<style is:global>
  /* Íconos SVG dentro del modal y trigger de agendar: siempre visibles */
  #agendarModal .icono-svg path,
  #agendarModal .icono-svg circle,
  #agendarModal .icono-svg rect,
  #agendarModal .icono-svg line,
  #agendarModal .icono-svg polyline,
  #agendarTrigger .icono-svg path,
  #agendarTrigger .icono-svg circle,
  #agendarTrigger .icono-svg rect,
  #agendarTrigger .icono-svg line,
  #agendarTrigger .icono-svg polyline {
    stroke-dasharray: 0 !important;
    stroke-dashoffset: 0 !important;
  }

  /* Días del calendario (creados con JS, no reciben scoped styles) */
  #agendarModal .agendar-dia {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 500;
    border-radius: 50%;
    border: none;
    cursor: default;
    background: transparent;
    color: var(--gris-sub);
    transition: background 0.2s, color 0.2s, transform 0.2s, box-shadow 0.2s;
    font-family: var(--fuente-principal);
  }
  #agendarModal .agendar-dia-disponible {
    color: var(--acento);
    font-weight: 600;
    cursor: pointer;
    background: color-mix(in srgb, var(--acento) 8%, transparent);
  }
  #agendarModal .agendar-dia-disponible:hover {
    background: color-mix(in srgb, var(--acento) 18%, transparent);
    transform: scale(1.15);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--acento) 12%, transparent);
  }
  #agendarModal .agendar-dia-seleccionado {
    background: var(--btn-fondo) !important;
    color: var(--btn-texto) !important;
    transform: scale(1.1);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--btn-fondo) 40%, transparent);
  }
  #agendarModal .agendar-dia:disabled,
  #agendarModal .agendar-dia-pasado {
    color: var(--gris-titulo);
    opacity: 0.25;
    cursor: not-allowed;
    background: transparent;
  }
  #agendarModal .agendar-dia-finde {
    color: var(--gris-titulo);
    opacity: 0.15;
    cursor: not-allowed;
    background: transparent;
  }
  #agendarModal .agendar-dia-vacio { visibility: hidden; }
  #agendarModal .agendar-dia-hoy {
    box-shadow: inset 0 0 0 2px var(--acento);
    font-weight: 600;
    color: var(--texto);
  }

  /* Slots de horarios (creados con JS) */
  #agendarModal .agendar-slot {
    padding: 12px 8px;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--fuente-principal);
    color: var(--texto);
    background: var(--fondo-alt);
    border: 1px solid var(--borde);
    border-radius: var(--radio-pill);
    cursor: pointer;
    text-align: center;
    transition: border-color 0.2s, background 0.2s, transform 0.2s, color 0.2s, box-shadow 0.2s;
  }
  #agendarModal .agendar-slot:hover {
    border-color: var(--acento);
    color: var(--acento);
    transform: translateY(-2px);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--acento) 15%, transparent);
  }
  #agendarModal .agendar-slot-seleccionado {
    border-color: var(--acento);
    background: color-mix(in srgb, var(--acento) 12%, transparent);
    color: var(--acento);
    font-weight: 600;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--acento) 20%, transparent);
  }

  /* Botones del modal: forzar estilos globales */
  #agendarModal .boton-oscuro {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--btn-fondo);
    color: var(--btn-texto);
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: var(--radio-pill);
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
  }
  #agendarModal .boton-oscuro:hover {
    opacity: 0.82;
    transform: translateY(-2px);
  }
  #agendarModal .boton-fantasma {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--ghost-fondo);
    color: var(--ghost-texto);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    padding: 12px 24px;
    border-radius: var(--radio-pill);
    border: none;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  #agendarModal .boton-fantasma:hover {
    background: var(--borde);
    color: var(--texto);
    transform: translateY(-2px);
  }

  /* Ícono check de confirmación: sí se anima */
  .agendar-confirmar-icono .icono-svg path,
  .agendar-confirmar-icono .icono-svg circle {
    stroke-dasharray: 300 !important;
    stroke-dashoffset: 300 !important;
  }
  .agendar-confirmar-icono.dibujado .icono-svg path,
  .agendar-confirmar-icono.dibujado .icono-svg circle {
    stroke-dashoffset: 0 !important;
    transition: stroke-dashoffset 1.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
