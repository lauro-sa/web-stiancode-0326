---
import IconoSVG from './ui/IconoSVG.astro';
import Boton from './Boton.astro';
import { t } from '../i18n/utils.js';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

const HERRAMIENTAS = [
  { titulo: t(lang, 'lab_h01_titulo'),  desc: t(lang, 'lab_h01_desc'),   icono: 'candado' },
  { titulo: t(lang, 'lab_h02_titulo'),  desc: t(lang, 'lab_h02_desc'),   icono: 'qr' },
  { titulo: t(lang, 'lab_h03_titulo'),  desc: t(lang, 'lab_h03_desc'),   icono: 'wifi' },
  { titulo: t(lang, 'lab_h04_titulo'),  desc: t(lang, 'lab_h04_desc'),   icono: 'imagen' },
  { titulo: t(lang, 'lab_h05_titulo'),  desc: t(lang, 'lab_h05_desc'),   icono: 'audio' },
  { titulo: t(lang, 'lab_h06_titulo'),  desc: t(lang, 'lab_h06_desc'),   icono: 'paleta' },
  { titulo: t(lang, 'lab_h07_titulo'),  desc: t(lang, 'lab_h07_desc'),   icono: 'recortar' },
];

const TEXTO = {
  etiqueta:  t(lang, 'lab_etiqueta'),
  tituloN:   t(lang, 'lab_titulo_negro'),
  tituloG:   t(lang, 'lab_titulo_gris'),
  subtitulo: t(lang, 'lab_subtitulo'),
};
---

<div class="fondo-puntos">
  <div class="panel-interior">
    <section class="seccion" id="laboratorio">

      <span class="etiqueta">{TEXTO.etiqueta}</span>
      <h2 class="titulo-dos-tonos">
        <span class="negro">{TEXTO.tituloN}</span><br>
        <span class="gris">{TEXTO.tituloG}</span>
      </h2>
      <p class="typewriter" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}>{TEXTO.subtitulo}</p>

      <div class="lab-preview-grilla">
        {HERRAMIENTAS.map((h) => (
          <a class="lab-preview-card" href={lang === 'en' ? '/en/lab' : '/laboratorio'}>
            <div class="icono-contenedor lab-preview-icono">
              <IconoSVG nombre={h.icono} tamaño={20} grosor={1.5} />
            </div>
            <div class="lab-preview-texto">
              <span class="lab-preview-titulo">{h.titulo}</span>
              <span class="lab-preview-desc">{h.desc}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="lab-ver-todas">
        <Boton variante="fantasma" href={lang === 'en' ? '/en/lab' : '/laboratorio'}>
          {t(lang, 'lab_boton')}
        </Boton>
      </div>

    </section>
  </div>
</div>

<style>
  .lab-preview-grilla {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .lab-preview-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--card);
    border: 1px solid var(--borde);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, border-color 0.25s, transform 0.25s;
  }

  .lab-preview-card:hover {
    background: var(--ghost-fondo);
    border-color: var(--acento);
    transform: translateY(-2px);
  }

  .lab-preview-card:hover .lab-preview-icono {
    transform: scale(1.1) rotate(-5deg);
  }

  .lab-preview-icono {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    flex-shrink: 0;
    transition: background 0.5s, transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .lab-preview-texto {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .lab-preview-titulo {
    font-size: 14px;
    font-weight: 700;
    color: var(--texto);
    transition: color 0.5s;
  }

  .lab-preview-desc {
    font-size: 12px;
    color: var(--gris-sub);
    transition: color 0.5s;
  }

  .lab-ver-todas { margin-top: 28px; }

  /* Animación lenta para los íconos */
  .lab-preview-card.dibujado .icono-svg path,
  .lab-preview-card.dibujado .icono-svg circle,
  .lab-preview-card.dibujado .icono-svg rect,
  .lab-preview-card.dibujado .icono-svg line,
  .lab-preview-card.dibujado .icono-svg polyline {
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 1.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 768px) {
    .lab-preview-grilla { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .lab-preview-grilla { grid-template-columns: 1fr; }
    .lab-preview-card { padding: 14px 16px; gap: 12px; }
  }
</style>

<script>
  const labCards = document.querySelectorAll('.lab-preview-card');

  const labObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const allCards = Array.from(labCards);
        const idx = allCards.indexOf(entry.target as HTMLElement);
        const delay = idx >= 0 ? idx * 120 : 0;
        setTimeout(() => {
          entry.target.classList.add('dibujado');
        }, delay);
        labObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  labCards.forEach(card => labObserver.observe(card));
</script>
