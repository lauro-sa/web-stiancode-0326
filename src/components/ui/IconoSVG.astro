// Obtener el contenido del ícono solicitado
const contenidoIcono = ICONOS[nombre] ?? ICONOS['flecha'];
---

<!-- Ícono SVG — la clase .icono-svg activa la animación via CSS global -->
<svg
  class={`icono-svg ${clase}`}
  width={tamaño}
  height={tamaño}
  viewBox="0 0 24 24"
  stroke-width={grosor}
  aria-hidden="true"
  set:html={contenidoIcono}
/>
