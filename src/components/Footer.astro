---
// ============================================================
// Footer.astro — Footer anclado al fondo con animaciones
// Está al final del contenido. Jello al overscroll, expand al click.
// ============================================================
import { t, getLocalizedUrl } from '../i18n/utils.js';
import { CONTACTO } from '../config.js';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;
const otroIdioma = lang === 'es' ? 'en' : 'es';
const urlOtroIdioma = getLocalizedUrl(Astro.url, otroIdioma);

const DATOS = CONTACTO;

const AÑO = new Date().getFullYear();
---

<div class="footer-wrapper">
  <footer id="footer-flotante" class="footer-flotante">
    <!-- Barra principal -->
    <div class="footer-barra" id="footer-barra">
      <div class="footer-barra-izq">
        <img class="footer-logo-img" src="/logo-claro.png" alt="S7ian Code" width="22" height="22" />
        <span class="footer-nombre">S7ian Code</span>
        <span class="footer-separador">·</span>
        <span class="footer-copy">© {AÑO}</span>
      </div>

      <div class="footer-barra-centro">
        <div class="footer-redes-mini">
          <a href={DATOS.github} class="red-mini" title="GitHub" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/></svg>
          </a>
          <a href={DATOS.linkedin} class="red-mini" title="LinkedIn" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href={DATOS.instagram} class="red-mini" title="Instagram" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href={`mailto:${DATOS.email}`} class="red-mini" title="Email" aria-label="Email">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-barra-der">
        <a href={urlOtroIdioma} class="boton-idioma-footer" aria-label={otroIdioma === 'en' ? 'Switch to English' : 'Cambiar a español'}>
          {t(otroIdioma, 'idioma_codigo')}
        </a>
        <button id="boton-tema-footer" class="boton-tema-footer" aria-label="Cambiar tema">
          <svg class="icono-tema icono-sol" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icono-tema icono-sistema" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <svg class="icono-tema icono-luna" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <span class="footer-separador-controles">|</span>
        <span class="footer-hint">{t(lang, 'footer_expandir')}</span>
        <svg class="footer-chevron footer-chevron-desktop" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
      </div>

      <div class="footer-chevron-mobile-wrap">
        <svg class="footer-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
      </div>
    </div>

    <!-- Panel expandible -->
    <div class="footer-panel" id="footer-panel">
      <div class="footer-panel-contenido">
        <div class="footer-grid">

          <div class="footer-col-marca">
            <p class="footer-desc">{t(lang, 'footer_desc')}</p>
            <div class="footer-redes-grandes">
              <a href={DATOS.github} class="red-social-grande" title="GitHub" target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/></svg>
              </a>
              <a href={DATOS.linkedin} class="red-social-grande" title="LinkedIn" target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              </a>
              <a href={DATOS.instagram} class="red-social-grande" title="Instagram" target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            </div>
          </div>

          <div class="footer-col">
            <h4>{t(lang, 'footer_servicios')}</h4>
            <ul role="list">
              <li><a href={lang === 'en' ? '/en/#servicios' : '/#servicios'}>{t(lang, 'footer_desarrollo_web')}</a></li>
              <li><a href={lang === 'en' ? '/en/#servicios' : '/#servicios'}>{t(lang, 'footer_aplicaciones_pwa')}</a></li>
              <li><a href={lang === 'en' ? '/en/#servicios' : '/#servicios'}>{t(lang, 'footer_diseno_integral')}</a></li>
              <li><a href={lang === 'en' ? '/en/#servicios' : '/#servicios'}>{t(lang, 'footer_optimizacion_seo')}</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>{t(lang, 'footer_proyectos')}</h4>
            <ul role="list">
              <li><a href="https://www.herreelec.com/" target="_blank" rel="noopener">HERREELEC →</a></li>
              <li><a href="https://esar-c221b.web.app/" target="_blank" rel="noopener">EsAr Digital →</a></li>
              <li><a href={lang === 'en' ? '/en/#proyectos' : '/#proyectos'}>{t(lang, 'footer_ver_todos')}</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>{t(lang, 'footer_contacto')}</h4>
            <ul role="list">
              <li><a href={`mailto:${DATOS.email}`}>{t(lang, 'footer_correo')}</a></li>
              <li><a href={lang === 'en' ? '/en/contact' : '/contacto'}>{t(lang, 'footer_formulario')}</a></li>
            </ul>
            <div class="footer-legal">
              <a href={lang === 'en' ? '/en/privacy' : '/privacidad'}>{t(lang, 'legal_footer_privacidad')}</a>
              <span class="footer-legal-sep">·</span>
              <a href={lang === 'en' ? '/en/terms' : '/terminos'}>{t(lang, 'legal_footer_terminos')}</a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </footer>
</div>

<style>
  /* Wrapper para que el footer quede al final del flujo normal */
  .footer-wrapper {
    display:flex;justify-content:center;
    padding:40px 0 calc(env(safe-area-inset-bottom) + 32px);position:relative;z-index:100;
  }

  .footer-flotante {
    position:relative;isolation:isolate;
    width:85%;max-width:1200px;
    border-radius:18px;overflow:hidden;
    border:none;
    background:transparent;
    box-shadow:0 -4px 30px rgba(0,0,0,.1);
    transition:box-shadow .4s;
    cursor:pointer;
  }

  /* Capa gradiente que rota — siempre detrás del contenido */
  .footer-flotante::before {
    content:'';position:absolute;inset:0;
    background:conic-gradient(from var(--angulo,0deg),#8964e8,#4c9cd0,#8964e8);
    animation:rotar-borde 3s linear infinite;
    opacity:0;transition:opacity .4s;
    z-index:0;
  }
  .footer-flotante:hover::before,
  .footer-flotante.abierto::before { opacity:1; }

  @property --angulo {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
  @keyframes rotar-borde {
    to { --angulo: 360deg; }
  }

  .footer-flotante:hover { animation:saltito .6s ease; }
  @media (max-width:1024px) { .footer-flotante:hover { animation:none; } }
  .footer-flotante.jello { animation:jello-vertical 1.9s both; }
  .footer-flotante.abierto { cursor:default; }
  .footer-flotante.abierto .footer-chevron { transform:rotate(180deg); }
  .footer-flotante.abierto .footer-hint { opacity:0;width:0;overflow:hidden; }

  /* ---- Barra con 3 columnas iguales ---- */
  .footer-barra {
    display:grid;grid-template-columns:1fr auto 1fr;align-items:center;
    padding:16px 28px;position:relative;z-index:1;
    background:var(--card);transition:background .4s;
    /* 1px de margen = 1px de borde gradiente visible */
    margin:0.5px;border-radius:17.5px 17.5px 0 0;
  }
  .footer-flotante:not(.abierto) .footer-barra { border-radius:17px; }

  .footer-barra-izq { display:flex;align-items:center;gap:10px;justify-self:start; }
  .footer-logo-img { width:22px;height:22px;object-fit:contain; }
  .footer-nombre { font-size:14px;font-weight:700;color:var(--texto);transition:color .4s; }
  .footer-separador { color:var(--gris-titulo);font-size:14px; }
  .footer-copy { font-size:12px;color:var(--gris-sub);transition:color .4s; }

  .footer-barra-centro { display:flex;align-items:center;justify-self:center; }
  .footer-redes-mini { display:flex;gap:6px; }
  .red-mini {
    width:30px;height:30px;border-radius:8px;
    background:var(--ghost-fondo);border:1px solid var(--borde);
    display:flex;align-items:center;justify-content:center;
    text-decoration:none;color:var(--gris-sub);
    transition:color .2s,background .2s,transform .2s,border-color .4s;
    animation:titileo 4s infinite ease-in-out;
  }
  .red-mini:hover { color:var(--texto);background:var(--fondo);transform:scale(1.12); }

  .footer-barra-der { display:flex;align-items:center;gap:8px;justify-self:end; }

  .boton-idioma-footer {
    width:30px;height:30px;border-radius:50%;
    background:var(--ghost-fondo);border:1px solid var(--borde);
    display:flex;align-items:center;justify-content:center;
    cursor:pointer;text-decoration:none;
    font-size:10px;font-weight:700;letter-spacing:.03em;
    color:var(--gris-sub);
    transition:background .2s,border-color .3s,color .2s;
  }
  .boton-idioma-footer:hover { background:var(--borde);color:var(--texto); }
  .boton-idioma-footer:active { transform:scale(.92); }

  .boton-tema-footer {
    width:30px;height:30px;border-radius:50%;
    background:var(--ghost-fondo);border:1px solid var(--borde);
    display:flex;align-items:center;justify-content:center;
    cursor:pointer;position:relative;overflow:hidden;
    transition:background .2s,border-color .3s;
  }
  .boton-tema-footer:hover { background:var(--borde); }
  .boton-tema-footer:active { transform:scale(.92); }
  .boton-tema-footer .icono-tema { width:14px;height:14px;color:var(--texto);position:absolute;transition:opacity .4s,transform .4s cubic-bezier(.4,0,.2,1);opacity:0;transform:scale(.4) rotate(90deg); }
  .boton-tema-footer .icono-tema.visible { opacity:1;transform:scale(1) rotate(0deg); }

  .footer-separador-controles { color:var(--borde);font-size:14px;margin:0 2px; }

  .footer-hint { font-size:12px;color:var(--gris-sub);transition:opacity .3s,width .3s;white-space:nowrap; }
  .footer-chevron { color:var(--gris-sub);transition:transform .3s,color .4s; }

  .footer-chevron-mobile-wrap { display:none; }

  /* ---- Panel expandible ---- */
  .footer-panel {
    max-height:0;overflow:hidden;
    transition:max-height .4s cubic-bezier(.4,0,.2,1);
    background:var(--card);
    margin:0 0.5px 0.5px;border-radius:0 0 17.5px 17.5px;
    position:relative;z-index:1;
  }
  .footer-flotante.abierto .footer-panel { max-height:320px; }

  .footer-panel-contenido {
    padding:4px 32px 28px;
    border-top:1px solid var(--borde);
  }

  .footer-grid {
    display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:36px;
    padding-top:24px;align-items:start;
  }

  .footer-desc { font-size:13px;color:var(--gris-sub);line-height:1.65;margin-bottom:14px;transition:color .4s; }

  .footer-redes-grandes { display:flex;gap:6px; }
  .red-social-grande {
    width:36px;height:36px;border-radius:9px;
    background:var(--ghost-fondo);border:1px solid var(--borde);
    display:flex;align-items:center;justify-content:center;
    text-decoration:none;color:var(--gris-sub);
    transition:color .2s,background .2s,transform .2s;
  }
  .red-social-grande:hover { color:var(--texto);background:var(--fondo);transform:scale(1.1); }

  .footer-col h4 { font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gris-titulo);margin-bottom:12px;transition:color .4s; }
  .footer-col ul { list-style:none;display:flex;flex-direction:column;gap:8px; }
  .footer-col a { font-size:13px;color:var(--gris-sub);text-decoration:none;transition:color .2s; }
  .footer-col a:hover { color:var(--texto); }

  .footer-legal { margin-top:14px;padding-top:10px;border-top:1px solid var(--borde);display:flex;align-items:center;gap:6px; }
  .footer-legal a { font-size:12px;color:var(--gris-sub);text-decoration:none;transition:color .2s; }
  .footer-legal a:hover { color:var(--texto); }
  .footer-legal-sep { color:var(--gris-sub);font-size:12px; }

  /* ---- Animaciones ---- */
  @keyframes jello-vertical {
    0%,100% { transform:scale3d(1,1,1); }
    30% { transform:scale3d(.96,1.04,1); }
    40% { transform:scale3d(1.04,.96,1); }
    50% { transform:scale3d(.98,1.02,1); }
    65% { transform:scale3d(1.02,.98,1); }
    75% { transform:scale3d(.99,1.01,1); }
  }

  @keyframes saltito {
    0%,100% { transform:translateY(0); }
    50% { transform:translateY(-5px); }
  }

  @keyframes titileo {
    0%,100% { opacity:1; }
    50% { opacity:.55; }
  }

  /* ---- Responsive ---- */
  @media (max-width:1024px) {
    .footer-flotante { width:92%; }
    .footer-grid { grid-template-columns:1fr 1fr;gap:28px; }
    .footer-flotante.abierto .footer-panel { max-height:420px; }
    .footer-panel-contenido { padding:4px 24px 24px; }
  }
  @media (max-width:600px) {
    .footer-flotante { width:96%;border-radius:14px; }
    .footer-barra { margin:0.5px;border-radius:13.5px 13.5px 0 0; }
    .footer-flotante:not(.abierto) .footer-barra { border-radius:13.5px; }
    .footer-panel-inner { margin:0 0.5px 0.5px;border-radius:0 0 13.5px 13.5px; }
    .footer-grid { grid-template-columns:1fr;gap:22px; }
    .footer-flotante.abierto .footer-panel { max-height:560px; }
    .footer-hint { display:none; }
    .footer-separador-controles { display:none; }
    .footer-chevron-desktop { display:none; }
    .footer-barra { padding:10px 18px 6px;grid-template-columns:1fr auto; }
    .footer-panel-contenido { padding:4px 18px 22px; }
    .footer-barra-centro { display:none; }
    .footer-copy { display:none; }
    .footer-separador { display:none; }
    .footer-chevron-mobile-wrap {
      display:flex;justify-content:center;
      grid-column:1 / -1;
      padding:2px 0 4px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const footer = document.getElementById('footer-flotante');
    const barra  = document.getElementById('footer-barra');
    if (!footer || !barra) return;

    let abierto = false;
    let animando = false;

    // Evitar que botones de tema/idioma abran el panel
    const botonTemaFooter = document.getElementById('boton-tema-footer');
    const botonIdiomaFooter = barra.querySelector('.boton-idioma-footer');
    if (botonTemaFooter) botonTemaFooter.addEventListener('click', (e) => e.stopPropagation());
    if (botonIdiomaFooter) {
      botonIdiomaFooter.addEventListener('click', (e) => {
        e.stopPropagation();
        const destino = botonIdiomaFooter.getAttribute('href') || '';
        const lang = destino.startsWith('/en') ? 'en' : 'es';
        localStorage.setItem('sc-idioma', lang);
      });
    }

    // Click para expandir/colapsar
    barra.addEventListener('click', () => {
      abierto = !abierto;
      footer.classList.toggle('abierto', abierto);
      if (abierto) {
        const panel = document.getElementById('footer-panel');
        if (panel) {
          panel.addEventListener('transitionend', function onEnd() {
            panel.removeEventListener('transitionend', onEnd);
            window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' });
          });
        }
      }
    });

    // Cerrar al hacer click fuera
    document.addEventListener('mousedown', (e) => {
      if (abierto && e.target instanceof Node && !footer.contains(e.target)) {
        abierto = false;
        footer.classList.remove('abierto');
      }
    });

    // Efecto jello al intentar scrollear más allá del fondo
    function estaAlFinal() {
      const { scrollTop, scrollHeight, clientHeight } = document.documentElement;
      return scrollTop + clientHeight >= scrollHeight - 2;
    }

    window.addEventListener('wheel', (e) => {
      if (estaAlFinal() && e.deltaY > 0 && !animando) {
        animando = true;
        footer.classList.add('jello');
        setTimeout(() => {
          footer.classList.remove('jello');
          animando = false;
        }, 1900);
      }
    }, { passive: true });

    // Touch support — sin jello en mobile para evitar saltos de scroll
  });
</script>
