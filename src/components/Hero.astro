---
// ============================================================
// Hero.astro — Hero de stiancode.dev
// ============================================================

// ---- Contenido editable ----
import Boton from './Boton.astro';
import { t } from '../i18n/utils.js';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

const CONTENIDO = {
  badge:           t(lang, 'hero_badge'),
  lineaNegra:      t(lang, 'hero_titulo_negro'),
  lineaGris:       t(lang, 'hero_titulo_gris'),
  subtitulo:       t(lang, 'hero_subtitulo'),
  botonPrimario:   t(lang, 'hero_boton_primario'),
  botonSecundario: t(lang, 'hero_boton_secundario'),
  linkPrimario:    lang === 'en' ? '/en/#projects' : '/#proyectos',
  linkSecundario:  lang === 'en' ? '/en/contact' : '/contacto',
};
---

<section class="hero" id="inicio">
  <canvas id="canvas-particulas-hero" class="canvas-hero"></canvas>

  <!-- Badge de disponibilidad -->
  <div class="hero-badge" style="opacity:0" aria-hidden="true">
    <span class="punto-disponible"></span>
    {CONTENIDO.badge}
  </div>

  <!-- Título -->
  <h1 class="hero-titulo" aria-label={`${CONTENIDO.lineaNegra} ${CONTENIDO.lineaGris}`}>
    <span class="linea-contenedor"><span class="linea-titulo negro">{CONTENIDO.lineaNegra}</span></span>
    <span class="linea-contenedor"><span class="linea-titulo gris impacto">{CONTENIDO.lineaGris}</span></span>
  </h1>

  <!-- Subtítulo -->
  <p class="hero-subtitulo" style="opacity:0">{CONTENIDO.subtitulo}</p>

  <!-- Botones -->
  <div class="hero-botones" style="opacity:0">
    <Boton href={CONTENIDO.linkPrimario}>
      {CONTENIDO.botonPrimario}
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </Boton>
    <Boton variante="fantasma" href={CONTENIDO.linkSecundario}>
      {CONTENIDO.botonSecundario}
    </Boton>
  </div>

</section>

<style>
  .hero { min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:100px 24px 80px;position:relative;z-index:2;overflow:hidden; }
  .canvas-hero { position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0; }
  .hero > *:not(.canvas-hero) { position:relative;z-index:1; }

  .hero-badge { display:inline-flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--borde);color:var(--gris-sub);font-size:13px;font-weight:500;padding:6px 14px;border-radius:100px;margin-bottom:28px;transition:background .5s,border-color .5s; }
  .punto-disponible { width:6px;height:6px;border-radius:50%;background:#22c55e;animation:pulso 2s infinite;flex-shrink:0; }
  @keyframes pulso { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.7)} }

  .hero-titulo { font-size:clamp(40px,9.5vw,100px);font-weight:500;line-height:1.0;letter-spacing:-3px;margin-bottom:24px; }
  .linea-contenedor { overflow:hidden;display:block; }
  .linea-contenedor:has(.impacto) { overflow:visible; }
  .linea-titulo     { display:block; }
  .linea-titulo.negro { color:var(--texto);transition:color .5s; }
  .linea-titulo.gris  { color:var(--gris-titulo);transition:color .5s; }

  .hero-subtitulo { font-size:17px;color:var(--gris-sub);max-width:500px;line-height:1.7;margin-bottom:36px;transition:color .5s; }

  .hero-botones { display:flex;align-items:center;gap:12px;flex-wrap:wrap;justify-content:center; }

  @media (max-width:600px) {
    .hero-titulo { letter-spacing:-2.5px; }
    .hero-botones { flex-direction:column;width:100%; }
    .hero-botones :global(.btn) { justify-content:center; }
  }
</style>
