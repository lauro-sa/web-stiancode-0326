---
// ============================================================
// SeccionSobre.astro — "Sobre mí" de stiancode.dev
// ============================================================
import Boton from './Boton.astro';
import { t } from '../i18n/utils.js';

interface Props { lang?: 'es' | 'en'; }
const { lang = 'es' } = Astro.props;

// ---- Contenido ----
const CONTENIDO = {
  parrafo1: t(lang, 'sobre_parrafo_1'),
  parrafo2: t(lang, 'sobre_parrafo_2'),
  parrafo3: t(lang, 'sobre_parrafo_3'),
  stats: [
    { numero: '+20',  etiqueta: t(lang, 'sobre_stat_proyectos') },
    { numero: '7+',   etiqueta: t(lang, 'sobre_stat_experiencia') },
    { numero: '+10',  etiqueta: t(lang, 'sobre_stat_certificaciones') },
    { numero: '0',    etiqueta: t(lang, 'sobre_stat_compromiso') },
  ],
};
---

<div class="fondo-puntos fondo-puntos-visible">
    <section class="seccion" id="sobre-mi">

      <span class="etiqueta">{t(lang, 'sobre_etiqueta')}</span>
      <h2 class="titulo-dos-tonos">
        <span class="negro">{t(lang, 'sobre_titulo_negro')}</span><br>
        <span class="gris">{t(lang, 'sobre_titulo_gris')}</span>
      </h2>

      <div class="sobre-grilla">

        <!-- Bio -->
        <div class="sobre-bio">
          <p>{CONTENIDO.parrafo1}</p>
          <p>{CONTENIDO.parrafo2}</p>
          <p>{CONTENIDO.parrafo3}</p>

          <div class="sobre-botones">
            <Boton href={lang === 'en' ? '/en/about' : '/sobre-mi'}>
              {t(lang, 'sobre_boton_recorrido')}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </Boton>
            <Boton variante="fantasma" href="https://github.com/lauro-sa" target="_blank" rel="noopener noreferrer">
              {t(lang, 'sobre_boton_github')}
            </Boton>
          </div>
        </div>

        <!-- Stats -->
        <div class="sobre-stats">
          {CONTENIDO.stats.map((stat) => (
            <div class="stat-item">
              <span class="stat-numero">{stat.numero}</span>
              <span class="stat-etiqueta">{stat.etiqueta}</span>
            </div>
          ))}
        </div>

      </div>
    </section>
</div>

<style>
  .sobre-grilla  { display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:40px;align-items:start; }
  .sobre-bio     { font-size:15px;color:var(--gris-sub);line-height:1.8;display:flex;flex-direction:column;gap:16px;transition:color .5s; }
  .sobre-botones { display:flex;gap:10px;flex-wrap:wrap;margin-top:12px; }

  .sobre-stats { display:flex;flex-direction:column;gap:0;background:transparent;border-radius:0;overflow:visible; }
  .stat-item   { background:transparent;padding:20px 24px;display:flex;flex-direction:column;gap:4px;border-bottom:1px solid var(--borde);transition:background .2s,border-color .5s,opacity .6s cubic-bezier(.22,1,.36,1),transform .6s cubic-bezier(.22,1,.36,1);opacity:0;transform:translateX(20px); }
  .stat-item:last-child { border-bottom:none; }
  .stat-item.visible { opacity:1;transform:translateX(0); }
  .stat-item:hover { background:color-mix(in srgb, var(--card) 50%, transparent); }
  .stat-numero  { font-size:28px;font-weight:700;color:var(--texto);letter-spacing:-1px;transition:color .5s; }
  .stat-etiqueta { font-size:13px;color:var(--gris-sub);transition:color .5s; }

  @media (max-width:768px) { .sobre-grilla { grid-template-columns:1fr; } }
</style>

<script>
  const stats = document.querySelectorAll('.stat-item');
  const statObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const all = Array.from(stats);
      const idx = all.indexOf(entry.target as HTMLElement);
      setTimeout(() => entry.target.classList.add('visible'), idx * 150);
      statObserver.unobserve(entry.target);
    });
  }, { threshold: 0.15 });
  stats.forEach((s) => statObserver.observe(s));
</script>
