<script>
  const _t = (window as any).__LAB || {};
  document.addEventListener('DOMContentLoaded', () => {

    // ============================================================
    // Animar íconos SVG de la grilla (con delay escalonado)
    // ============================================================
    const iconObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Delay escalonado según posición
          const cards = Array.from(document.querySelectorAll('.lab-card'));
          const idx = cards.indexOf(entry.target as HTMLElement);
          const delay = idx >= 0 ? idx * 150 : 0;
          setTimeout(() => {
            entry.target.classList.add('dibujado');
          }, delay);
          iconObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.lab-card').forEach(el => {
      iconObserver.observe(el);
    });

    // ============================================================
    // Sistema de modales
    // ============================================================
    const cards = document.querySelectorAll('.lab-card:not(.lab-card--pronto)');
    const overlays = document.querySelectorAll('.lab-modal-overlay');
    const cierres = document.querySelectorAll('.lab-modal-cerrar');

    function abrirModal(id: string) {
      const modal = document.getElementById(`modal-${id}`);
      if (!modal) return;
      modal.setAttribute('aria-hidden', 'false');
      modal.classList.add('activo');
      document.body.style.overflow = 'hidden';
      // Activar animación de íconos SVG + typewriter del título
      modal.querySelectorAll('.lab-modal-header-izq').forEach(el => el.classList.remove('dibujado'));
      modal.querySelectorAll('.icono-contenedor').forEach(el => el.classList.remove('dibujado'));

      // Resetear título para typewriter
      const tituloEl = modal.querySelector('.lab-modal-titulo') as HTMLElement;
      if (tituloEl) {
        const textoCompleto = tituloEl.dataset.texto || tituloEl.textContent || '';
        if (!tituloEl.dataset.texto) tituloEl.dataset.texto = textoCompleto;
        tituloEl.textContent = '';
        tituloEl.classList.add('lab-titulo-escribiendo');
      }

      setTimeout(() => {
        modal.querySelectorAll('.lab-modal-header-izq').forEach(el => el.classList.add('dibujado'));
        modal.querySelectorAll('.icono-contenedor').forEach(el => el.classList.add('dibujado'));

        // Typewriter del título
        if (tituloEl) {
          const texto = tituloEl.dataset.texto || '';
          let i = 0;
          const velocidad = 40;
          function escribir() {
            if (i < texto.length) {
              tituloEl.textContent = texto.slice(0, i + 1);
              i++;
              setTimeout(escribir, velocidad);
            } else {
              tituloEl.classList.remove('lab-titulo-escribiendo');
            }
          }
          escribir();
        }
      }, 200);
    }

    function cerrarModal() {
      overlays.forEach(m => {
        m.setAttribute('aria-hidden', 'true');
        m.classList.remove('activo');
      });
      document.body.style.overflow = '';
    }

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const id = (card as HTMLElement).dataset.herramienta;
        if (id) abrirModal(id);
      });
    });

    cierres.forEach(btn => btn.addEventListener('click', cerrarModal));
    overlays.forEach(ov => ov.addEventListener('click', (e) => { if (e.target === ov) cerrarModal(); }));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') cerrarModal(); });

    // Separar en try/catch para que un error no frene los modales
    try {
    // ============================================================
    // Generador de Contraseñas
    // ============================================================
    const $ = (id: string) => document.getElementById(id)!;
    const elPassword    = $('gen-password') as HTMLInputElement;
    const elCopiar      = $('gen-copiar');
    const elGenerar     = $('gen-generar');
    const elLargo       = $('gen-largo') as HTMLInputElement;
    const elLargoValor  = $('gen-largo-valor');
    const elFuerzaNivel = $('gen-fuerza-nivel') as HTMLElement;
    const elFuerzaTexto = $('gen-fuerza-texto');
    const elOpcionesPro = $('gen-opciones-pro');
    const elInfoUltra   = $('gen-info-ultra');
    const elMayusculas  = $('gen-mayusculas') as HTMLInputElement;
    const elMinusculas  = $('gen-minusculas') as HTMLInputElement;
    const elNumeros     = $('gen-numeros') as HTMLInputElement;
    const elSimbolos    = $('gen-simbolos') as HTMLInputElement;
    const elGuiones     = $('gen-guiones') as HTMLInputElement;

    let modoActual = 'segura';

    // Charsets
    const CHARS = {
      mayusculas: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      minusculas: 'abcdefghijklmnopqrstuvwxyz',
      numeros:    '0123456789',
      simbolos:   '!@#$%^&*()_+-=[]{}|;:,.<>?',
      ultra:      '!@#$%^&*()_+-=[]{}|;:,.<>?~`§±©®™°¶∆∑∏√∫≈≠≤≥αβγδεζηθλμπσφψωΩ¥£€₿¢«»†‡‰¿¡±÷×',
    };

    // --- Generar contraseña estilo Google/iOS (con guiones) ---
    function generarSegura(largo: number): string {
      const charset = CHARS.mayusculas + CHARS.minusculas + CHARS.numeros;
      const grupoSize = 4;
      // Generar caracteres sin guiones primero
      const totalChars = largo;
      const arr = new Uint32Array(totalChars);
      crypto.getRandomValues(arr);
      let chars = Array.from(arr, v => charset[v % charset.length]).join('');
      // Insertar guiones cada 4 caracteres
      const grupos: string[] = [];
      for (let i = 0; i < chars.length; i += grupoSize) {
        grupos.push(chars.slice(i, i + grupoSize));
      }
      return grupos.join('-');
    }

    // --- Generar contraseña Pro (configurable) ---
    function generarPro(largo: number): string {
      let charset = '';
      if (elMayusculas.checked) charset += CHARS.mayusculas;
      if (elMinusculas.checked) charset += CHARS.minusculas;
      if (elNumeros.checked)    charset += CHARS.numeros;
      if (elSimbolos.checked)   charset += CHARS.simbolos;
      if (!charset) { elMinusculas.checked = true; charset = CHARS.minusculas; }

      const arr = new Uint32Array(largo);
      crypto.getRandomValues(arr);
      let password = Array.from(arr, v => charset[v % charset.length]).join('');

      if (elGuiones.checked) {
        const grupos: string[] = [];
        for (let i = 0; i < password.length; i += 4) {
          grupos.push(password.slice(i, i + 4));
        }
        password = grupos.join('-');
      }
      return password;
    }

    // --- Generar contraseña Ultra ---
    function generarUltra(largo: number): string {
      const charset = CHARS.mayusculas + CHARS.minusculas + CHARS.numeros + CHARS.ultra;
      const arr = new Uint32Array(largo);
      crypto.getRandomValues(arr);
      return Array.from(arr, v => charset[v % charset.length]).join('');
    }

    // --- Generar según modo ---
    function generar() {
      const largo = parseInt(elLargo.value);
      let password: string;
      let charsetSize: number;

      switch (modoActual) {
        case 'segura':
          password = generarSegura(largo);
          charsetSize = 62; // a-z A-Z 0-9
          break;
        case 'pro':
          password = generarPro(largo);
          charsetSize = 0;
          if (elMayusculas.checked) charsetSize += 26;
          if (elMinusculas.checked) charsetSize += 26;
          if (elNumeros.checked)    charsetSize += 10;
          if (elSimbolos.checked)   charsetSize += 28;
          if (charsetSize === 0) charsetSize = 26;
          break;
        case 'ultra':
          password = generarUltra(largo);
          charsetSize = 62 + CHARS.ultra.length;
          break;
        default:
          password = generarSegura(largo);
          charsetSize = 62;
      }

      elPassword.value = password;
      actualizarFuerza(largo, charsetSize);
    }

    // --- Fuerza ---
    function actualizarFuerza(largo: number, charsetSize: number) {
      const bits = Math.log2(charsetSize) * largo;
      let nivel: number, texto: string, color: string;

      if (bits < 40)       { nivel = 15;  texto = _t.fuerza_muy_debil || 'Muy débil';       color = '#ef4444'; }
      else if (bits < 60)  { nivel = 30;  texto = _t.fuerza_debil || 'Débil';             color = '#f97316'; }
      else if (bits < 80)  { nivel = 50;  texto = _t.fuerza_aceptable || 'Aceptable';     color = '#eab308'; }
      else if (bits < 100) { nivel = 70;  texto = _t.fuerza_fuerte || 'Fuerte';           color = '#22c55e'; }
      else if (bits < 130) { nivel = 85;  texto = _t.fuerza_muy_fuerte || 'Muy fuerte';   color = '#10b981'; }
      else                 { nivel = 100; texto = _t.fuerza_impenetrable || 'Impenetrable'; color = '#06b6d4'; }

      elFuerzaNivel.style.width = nivel + '%';
      elFuerzaNivel.style.background = color;
      elFuerzaTexto.textContent = texto;
      elFuerzaTexto.style.color = color;
    }

    // --- Modos ---
    document.querySelectorAll('.gen-modo').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.gen-modo').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        modoActual = (btn as HTMLElement).dataset.modo || 'segura';

        elOpcionesPro.style.display = modoActual === 'pro' ? '' : 'none';
        elInfoUltra.style.display = modoActual === 'ultra' ? '' : 'none';

        // Mostrar descripción del modo
        document.querySelectorAll('.gen-modo-info-texto').forEach(el => {
          (el as HTMLElement).style.display = 'none';
        });
        const infoEl = document.getElementById(`gen-modo-info-${modoActual}`);
        if (infoEl) infoEl.style.display = '';

        generar();
      });
    });

    // --- Slider ---
    function actualizarSlider() {
      elLargoValor.textContent = elLargo.value;
      const pct = ((parseInt(elLargo.value) - 8) / (64 - 8)) * 100;
      elLargo.style.setProperty('--pct', pct + '%');
    }

    elLargo.addEventListener('input', () => { actualizarSlider(); generar(); });
    actualizarSlider();

    // --- Presets de largo ---
    document.querySelectorAll('.gen-preset').forEach(btn => {
      btn.addEventListener('click', () => {
        const largo = (btn as HTMLElement).dataset.largo || '16';
        elLargo.value = largo;
        document.querySelectorAll('.gen-preset').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        actualizarSlider();
        generar();
      });
    });

    // --- Toggles Pro ---
    [elMayusculas, elMinusculas, elNumeros, elSimbolos, elGuiones].forEach(el => {
      el.addEventListener('change', generar);
    });

    // --- Botón generar ---
    elGenerar.addEventListener('click', generar);

    // --- Copiar ---
    elCopiar.addEventListener('click', async () => {
      const text = elPassword.value;
      if (!text) return;
      await navigator.clipboard.writeText(text);
      elCopiar.classList.add('gen-copiar--ok');
      setTimeout(() => elCopiar.classList.remove('gen-copiar--ok'), 1500);
    });

    // --- Recalcular fuerza al editar manualmente ---
    elPassword.addEventListener('input', () => {
      const val = elPassword.value;
      const unique = new Set(val).size;
      actualizarFuerza(val.length, Math.max(unique, 26));
    });

    // --- Auto-generar al abrir modal ---
    const observer = new MutationObserver(() => {
      const modal = document.getElementById('modal-contrasenas');
      if (modal?.classList.contains('activo') && !elPassword.value) {
        generar();
      }
    });
    const modalC = document.getElementById('modal-contrasenas');
    if (modalC) observer.observe(modalC, { attributes: true, attributeFilter: ['class'] });

    // ============================================================
    // Generador de Códigos QR
    // ============================================================
    const qrCanvas     = document.getElementById('qr-canvas') as HTMLCanvasElement;
    // Pre-inicializar contexto con willReadFrequently para evitar warning
    qrCanvas.getContext('2d', { willReadFrequently: true });
    const qrUrl        = document.getElementById('qr-url') as HTMLInputElement;
    const qrDotColor   = document.getElementById('qr-dot-color') as HTMLInputElement;
    const qrFondoColor = document.getElementById('qr-fondo-color') as HTMLInputElement;
    const qrLogoToggle = document.getElementById('qr-logo-toggle') as HTMLInputElement;
    const qrLogoOpts   = document.getElementById('qr-logo-opciones')!;
    const qrLogoFile   = document.getElementById('qr-logo-file') as HTMLInputElement;
    const qrTamano     = document.getElementById('qr-tamano') as HTMLInputElement;
    const qrTamanoVal  = document.getElementById('qr-tamano-valor')!;
    const qrDescargar  = document.getElementById('qr-descargar')!;
    const qrCopiarBtn  = document.getElementById('qr-copiar')!;
    const qrFondoCustom = document.getElementById('qr-fondo-custom')!;

    let qrFondoTipo = 'transparente';
    let qrColorDots = '#000000';
    let qrUsarLogo = true;
    let qrLogoCustom: HTMLImageElement | null = null;
    let qrLogoTipo = 'sitio';

    // Cargar logo del sitio
    const logoSitio = new Image();
    logoSitio.crossOrigin = 'anonymous';
    logoSitio.src = '/favicon.png';

    // Importar librería QR
    async function loadQR() {
      // @ts-ignore
      const QRCode = await import('qrcode');
      return QRCode.default || QRCode;
    }

    function getBgColor(): string {
      switch (qrFondoTipo) {
        case 'transparente': return 'rgba(0,0,0,0)';
        case 'blanco':       return '#ffffff';
        case 'negro':        return '#111111';
        case 'custom':       return qrFondoColor.value;
        default:             return 'rgba(0,0,0,0)';
      }
    }

    // Reemplazar píxeles de un color por transparente
    function hacerTransparente(canvas: HTMLCanvasElement, colorHex: string) {
      const ctx = canvas.getContext('2d', { willReadFrequently: true })!;
      const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
      const tr = parseInt(colorHex.slice(1, 3), 16);
      const tg = parseInt(colorHex.slice(3, 5), 16);
      const tb = parseInt(colorHex.slice(5, 7), 16);
      const tolerancia = 40; // alta tolerancia para atrapar anti-aliasing

      for (let i = 0; i < imgData.data.length; i += 4) {
        const dr = Math.abs(imgData.data[i] - tr);
        const dg = Math.abs(imgData.data[i + 1] - tg);
        const db = Math.abs(imgData.data[i + 2] - tb);
        if (dr < tolerancia && dg < tolerancia && db < tolerancia) {
          imgData.data[i + 3] = 0;
        }
      }
      ctx.putImageData(imgData, 0, 0);
    }

    async function generarQR() {
      const QRCode = await loadQR();
      const url = qrUrl.value.trim() || 'https://stiancode.dev';
      const previewSize = 280;
      const bgColor = getBgColor();
      const esTransparente = qrFondoTipo === 'transparente';

      // Para transparente: generar con un fondo temporal y después borrarlo
      const tempBg = esTransparente
        ? (qrColorDots === '#ffffff' ? '#000000' : '#ffffff')
        : bgColor;

      // Generar QR en canvas
      try {
        await QRCode.toCanvas(qrCanvas, url, {
          width: previewSize,
          margin: 2,
          color: {
            dark: qrColorDots,
            light: tempBg,
          },
          errorCorrectionLevel: qrUsarLogo ? 'H' : 'M',
        });

        // Si es transparente, eliminar el fondo temporal
        if (esTransparente) {
          hacerTransparente(qrCanvas, tempBg);
        }

        // Dibujar logo si está activo
        if (qrUsarLogo) {
          const logo = qrLogoTipo === 'custom' && qrLogoCustom ? qrLogoCustom : logoSitio;
          if (logo.complete && logo.naturalWidth > 0) {
            dibujarLogoSobreQR(qrCanvas, logo);
          }
        }
      } catch (err) {
        console.error('Error generando QR:', err);
      }
    }

    function dibujarLogoSobreQR(canvas: HTMLCanvasElement, logo: HTMLImageElement, dotColor?: string) {
      const colorBorde = dotColor || qrColorDots;
      const ctx = canvas.getContext('2d')!;
      const borderWidth = Math.ceil(canvas.width * 0.008);
      const padding = Math.ceil(canvas.width * 0.015);
      const logoSize = Math.ceil(canvas.width * 0.14);
      const boxSize = logoSize + padding * 2;
      const outerSize = boxSize + borderWidth * 2;
      const r = Math.ceil(outerSize * 0.18);

      const ox = (canvas.width - outerSize) / 2;
      const oy = (canvas.height - outerSize) / 2;
      const bx = ox + borderWidth;
      const by = oy + borderWidth;
      const lx = bx + padding;
      const ly = by + padding;

      // Crear un canvas temporal con solo el logo box
      const tmpCanvas = document.createElement('canvas');
      tmpCanvas.width = canvas.width;
      tmpCanvas.height = canvas.height;
      const tmpCtx = tmpCanvas.getContext('2d')!;

      // Marco redondeado del color del código QR
      tmpCtx.fillStyle = colorBorde;
      tmpCtx.beginPath();
      tmpCtx.roundRect(ox, oy, outerSize, outerSize, r);
      tmpCtx.fill();

      // Interior: siempre transparente (solo queda el marco + logo)
      tmpCtx.save();
      tmpCtx.globalCompositeOperation = 'destination-out';
      tmpCtx.beginPath();
      tmpCtx.roundRect(bx, by, boxSize, boxSize, r - borderWidth);
      tmpCtx.fill();
      tmpCtx.restore();

      // Logo
      tmpCtx.imageSmoothingEnabled = true;
      tmpCtx.imageSmoothingQuality = 'high';
      tmpCtx.drawImage(logo, lx, ly, logoSize, logoSize);

      // Ahora limpiar la zona en el canvas principal y pegar el logo box
      ctx.save();
      ctx.beginPath();
      ctx.roundRect(ox - 1, oy - 1, outerSize + 2, outerSize + 2, r + 1);
      ctx.globalCompositeOperation = 'destination-out';
      ctx.fill();
      ctx.restore();
      ctx.globalCompositeOperation = 'source-over';

      // Pegar el logo box completo encima
      ctx.drawImage(tmpCanvas, 0, 0);
    }

    // --- Generar QR para descarga a tamaño real ---
    async function generarQRDescarga(): Promise<HTMLCanvasElement> {
      const QRCode = await loadQR();
      const url = qrUrl.value.trim() || 'https://stiancode.dev';
      const tamano = parseInt(qrTamano.value);
      const bgColor = getBgColor();
      const esTransparente = qrFondoTipo === 'transparente';
      const tempBg = esTransparente
        ? (qrColorDots === '#ffffff' ? '#000000' : '#ffffff')
        : bgColor;

      const canvas = document.createElement('canvas');
      await QRCode.toCanvas(canvas, url, {
        width: tamano,
        margin: 2,
        color: { dark: qrColorDots, light: tempBg },
        errorCorrectionLevel: qrUsarLogo ? 'H' : 'M',
      });

      if (esTransparente) {
        hacerTransparente(canvas, tempBg);
      }

      if (qrUsarLogo) {
        const logo = qrLogoTipo === 'custom' && qrLogoCustom ? qrLogoCustom : logoSitio;
        if (logo.complete && logo.naturalWidth > 0) {
          dibujarLogoSobreQR(canvas, logo);
        }
      }

      return canvas;
    }

    // --- Eventos QR ---

    // URL: generar al escribir (con debounce)
    let qrTimer: ReturnType<typeof setTimeout>;
    qrUrl.addEventListener('input', () => {
      clearTimeout(qrTimer);
      qrTimer = setTimeout(generarQR, 300);
    });

    // Colores rápidos
    document.querySelectorAll('.qr-color-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.qr-color-btn').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        const color = (btn as HTMLElement).dataset.color;
        if (color) {
          qrColorDots = color;
          qrDotColor.value = color;
          qrDotHex.value = color;
          generarQR();
        }
      });
    });

    const qrDotHex   = document.getElementById('qr-dot-hex') as HTMLInputElement;
    const qrFondoHex = document.getElementById('qr-fondo-hex') as HTMLInputElement;

    // Sincronizar picker ↔ hex para color del código
    qrDotColor.addEventListener('input', () => {
      qrColorDots = qrDotColor.value;
      qrDotHex.value = qrDotColor.value;
      document.querySelectorAll('.qr-color-btn').forEach(b => b.classList.remove('activo'));
      generarQR();
    });

    qrDotHex.addEventListener('input', () => {
      const val = qrDotHex.value;
      if (/^#[0-9a-fA-F]{6}$/.test(val)) {
        qrColorDots = val;
        qrDotColor.value = val;
        document.querySelectorAll('.qr-color-btn').forEach(b => b.classList.remove('activo'));
        generarQR();
      }
    });

    // Fondo
    document.querySelectorAll('.qr-opcion-fondo').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.qr-opcion-fondo').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        qrFondoTipo = (btn as HTMLElement).dataset.fondo || 'transparente';
        qrFondoCustom.style.display = qrFondoTipo === 'custom' ? 'flex' : 'none';

        // Auto-ajustar color QR según fondo para que sea legible
        function setDotColor(color: string) {
          qrColorDots = color;
          qrDotColor.value = color;
          qrDotHex.value = color;
          document.querySelectorAll('.qr-color-btn').forEach(b => b.classList.remove('activo'));
          document.querySelector(`.qr-color-btn[data-color="${color}"]`)?.classList.add('activo');
        }

        const esOscuro = document.documentElement.getAttribute('data-tema') === 'oscuro';

        if (qrFondoTipo === 'negro') {
          setDotColor('#ffffff');
        } else if (qrFondoTipo === 'blanco') {
          setDotColor('#000000');
        } else if (qrFondoTipo === 'transparente') {
          setDotColor(esOscuro ? '#ffffff' : '#000000');
        }

        generarQR();
      });
    });

    qrFondoColor.addEventListener('input', () => {
      qrFondoHex.value = qrFondoColor.value;
      generarQR();
    });

    qrFondoHex.addEventListener('input', () => {
      const val = qrFondoHex.value;
      if (/^#[0-9a-fA-F]{6}$/.test(val)) {
        qrFondoColor.value = val;
        generarQR();
      }
    });

    // Logo toggle
    qrLogoToggle.addEventListener('change', () => {
      qrUsarLogo = qrLogoToggle.checked;
      qrLogoOpts.style.display = qrUsarLogo ? '' : 'none';
      generarQR();
    });

    // Logo tipo
    document.querySelectorAll('.qr-logo-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.qr-logo-btn').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        qrLogoTipo = (btn as HTMLElement).dataset.logo || 'sitio';
        generarQR();
      });
    });

    // Logo custom upload
    qrLogoFile.addEventListener('change', () => {
      const file = qrLogoFile.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        qrLogoCustom = new Image();
        qrLogoCustom.onload = () => {
          qrLogoTipo = 'custom';
          document.querySelectorAll('.qr-logo-btn').forEach(b => b.classList.remove('activo'));
          document.getElementById('qr-logo-custom-label')?.classList.add('activo');
          generarQR();
        };
        qrLogoCustom.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    });

    // Tamaño
    qrTamano.addEventListener('input', () => {
      qrTamanoVal.textContent = qrTamano.value + 'px';
      const pct = ((parseInt(qrTamano.value) - 256) / (1024 - 256)) * 100;
      qrTamano.style.setProperty('--pct', pct + '%');
    });
    const qrPctInit = ((parseInt(qrTamano.value) - 256) / (1024 - 256)) * 100;
    qrTamano.style.setProperty('--pct', qrPctInit + '%');

    // Descargar
    qrDescargar.addEventListener('click', async () => {
      const qrCanvasDl = await generarQRDescarga();
      const tamano = parseInt(qrTamano.value);
      const footerH = 48;
      const totalH = tamano + footerH;

      // Canvas final con QR + branding
      const finalCanvas = document.createElement('canvas');
      finalCanvas.width = tamano;
      finalCanvas.height = totalH;
      const fCtx = finalCanvas.getContext('2d')!;

      // Fondo del footer
      const esOscuro = qrColorDots === '#ffffff' || qrFondoTipo === 'negro';
      fCtx.fillStyle = esOscuro ? '#111111' : '#ffffff';
      fCtx.fillRect(0, tamano, tamano, footerH);

      // QR
      fCtx.drawImage(qrCanvasDl, 0, 0);

