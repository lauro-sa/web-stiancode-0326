    // --- Utilidades HSL ↔ HEX ---
    function hslToRgb(h: number, s: number, l: number): [number, number, number] {
      h = ((h % 360) + 360) % 360;
      s = Math.max(0, Math.min(1, s));
      l = Math.max(0, Math.min(1, l));
      const c = (1 - Math.abs(2 * l - 1)) * s;
      const x = c * (1 - Math.abs((h / 60) % 2 - 1));
      const m = l - c / 2;
      let r = 0, g = 0, b = 0;
      if (h < 60)       { r = c; g = x; b = 0; }
      else if (h < 120) { r = x; g = c; b = 0; }
      else if (h < 180) { r = 0; g = c; b = x; }
      else if (h < 240) { r = 0; g = x; b = c; }
      else if (h < 300) { r = x; g = 0; b = c; }
      else              { r = c; g = 0; b = x; }
      return [Math.round((r + m) * 255), Math.round((g + m) * 255), Math.round((b + m) * 255)];
    }

    function rgbToHex(r: number, g: number, b: number): string {
      return '#' + [r, g, b].map(v => v.toString(16).padStart(2, '0')).join('');
    }

    function hslToHex(h: number, s: number, l: number): string {
      const [r, g, b] = hslToRgb(h, s, l);
      return rgbToHex(r, g, b);
    }


    // --- Algoritmos de armonía ---
    function randomHue(): number { return Math.random() * 360; }
    function randomSat(): number { return 0.45 + Math.random() * 0.4; } // 45%-85%
    function randomLig(): number { return 0.35 + Math.random() * 0.35; } // 35%-70%
    function varyLig(base: number, range = 0.15): number {
      return Math.max(0.2, Math.min(0.8, base + (Math.random() - 0.5) * range * 2));
    }
    function varySat(base: number, range = 0.1): number {
      return Math.max(0.25, Math.min(0.9, base + (Math.random() - 0.5) * range * 2));
    }

    function generarPaletaRandom(): string[] {
      const colores: string[] = [];
      const hBase = randomHue();
      for (let i = 0; i < 5; i++) {
        const h = (hBase + Math.random() * 360) % 360;
        colores.push(hslToHex(h, randomSat(), randomLig()));
      }
      return colores;
    }

    function generarPaletaAnalogos(): string[] {
      const hBase = randomHue();
      const s = randomSat();
      const l = randomLig();
      return [-30, -15, 0, 15, 30].map(offset =>
        hslToHex((hBase + offset + 360) % 360, varySat(s), varyLig(l))
      );
    }

    function generarPaletaComplementarios(): string[] {
      const hBase = randomHue();
      const s = randomSat();
      const l = randomLig();
      return [0, 15, 180, 195, 210].map(offset =>
        hslToHex((hBase + offset) % 360, varySat(s), varyLig(l))
      );
    }

    function generarPaletaTriadicos(): string[] {
      const hBase = randomHue();
      const s = randomSat();
      const l = randomLig();
      return [0, 10, 120, 130, 240].map(offset =>
        hslToHex((hBase + offset) % 360, varySat(s), varyLig(l))
      );
    }

    function generarPaletaSplit(): string[] {
      const hBase = randomHue();
      const s = randomSat();
      const l = randomLig();
      return [0, 15, 150, 180, 210].map(offset =>
        hslToHex((hBase + offset) % 360, varySat(s), varyLig(l))
      );
    }

