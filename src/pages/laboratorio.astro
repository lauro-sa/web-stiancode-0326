---
// ============================================================
// laboratorio.astro — Herramientas digitales interactivas
//
// Grilla de herramientas → clic abre modal con la herramienta
// funcionando. Solo 1 modal abierto a la vez.
// ============================================================
import { t } from '../i18n/utils.js';
import Plantilla from '../layouts/Plantilla.astro';
import Nav       from '../components/Nav.astro';
import Footer    from '../components/Footer.astro';
import IconoSVG  from '../components/ui/IconoSVG.astro';
import Boton     from '../components/Boton.astro';

const lang = 'es';

interface Herramienta {
  id:          string;
  numero:      string;
  titulo:      string;
  descripcion: string;
  icono:       string;
  disponible:  boolean;
}

const HERRAMIENTAS: Herramienta[] = [
  {
    id: 'contrasenas',
    numero: '01',
    titulo: t(lang, 'lab_pagina_h01_titulo'),
    descripcion: t(lang, 'lab_pagina_h01_desc'),
    icono: 'candado',
    disponible: true,
  },
  {
    id: 'qr',
    numero: '02',
    titulo: t(lang, 'lab_pagina_h02_titulo'),
    descripcion: t(lang, 'lab_pagina_h02_desc'),
    icono: 'qr',
    disponible: true,
  },
  {
    id: 'audio',
    numero: '03',
    titulo: t(lang, 'lab_pagina_h03_titulo'),
    descripcion: t(lang, 'lab_pagina_h03_desc'),
    icono: 'audio',
    disponible: false,
  },
  {
    id: 'imagen',
    numero: '04',
    titulo: t(lang, 'lab_pagina_h04_titulo'),
    descripcion: t(lang, 'lab_pagina_h04_desc'),
    icono: 'imagen',
    disponible: false,
  },
  {
    id: 'wifi',
    numero: '05',
    titulo: t(lang, 'lab_pagina_h05_titulo'),
    descripcion: t(lang, 'lab_pagina_h05_desc'),
    icono: 'wifi',
    disponible: true,
  },
  {
    id: 'paleta',
    numero: '06',
    titulo: t(lang, 'lab_pagina_h06_titulo'),
    descripcion: t(lang, 'lab_pagina_h06_desc'),
    icono: 'paleta',
    disponible: true,
  },
  {
    id: 'redimensionar',
    numero: '07',
    titulo: t(lang, 'lab_pagina_h07_titulo'),
    descripcion: t(lang, 'lab_pagina_h07_desc'),
    icono: 'recortar',
    disponible: true,
  },
];
---

<Plantilla
  titulo={t(lang, 'pagina_lab_titulo')}
  descripcion={t(lang, 'pagina_lab_desc')}
  lang={lang}
>
  <Nav lang={lang}/>

  <main>
    <div class="fondo-puntos fondo-puntos-visible">
        <section class="seccion" id="laboratorio">

          <span class="etiqueta">{t(lang, 'lab_etiqueta')}</span>
          <h2 class="titulo-dos-tonos">
            <span class="negro">{t(lang, 'lab_titulo_negro')}</span><br>
            <span class="gris">{t(lang, 'lab_titulo_gris')}</span>
          </h2>
          <p class="typewriter" data-texto={t(lang, 'lab_pagina_subtitulo')} aria-label={t(lang, 'lab_pagina_subtitulo')}>{t(lang, 'lab_pagina_subtitulo')}</p>

          <!-- Grilla de herramientas -->
          <div class="lab-grilla">
            {HERRAMIENTAS.map((h) => (
              <button
                class={`lab-card ${!h.disponible ? 'lab-card--pronto' : ''}`}
                data-herramienta={h.id}
                disabled={!h.disponible}
              >
                <div class="lab-card-top">
                  <div class="icono-contenedor lab-card-icono">
                    <IconoSVG nombre={h.icono} tamaño={22} grosor={1.5} />
                  </div>
                  <span class="lab-card-numero">{h.numero}</span>
                </div>
                <h3 class="lab-card-titulo">{h.titulo}</h3>
                <p class="lab-card-desc">{h.descripcion}</p>
                {h.disponible ? (
                  <span class="lab-card-accion">{t(lang, 'lab_abrir')}</span>
                ) : (
                  <span class="lab-card-pronto">{t(lang, 'lab_proximamente')}</span>
                )}
              </button>
            ))}
          </div>

          <div class="lab-volver">
            <Boton variante="fantasma" href={`${lang === 'en' ? '/en/' : '/'}#laboratorio`}>{t(lang, 'volver_inicio')}</Boton>
          </div>

        </section>
    </div>
  </main>

  <!-- ============================================================
       MODAL: Generador de Contraseñas
       ============================================================ -->
  <div class="lab-modal-overlay" id="modal-contrasenas" aria-hidden="true" role="dialog" aria-modal="true" aria-label={t(lang, 'lab_modal_pass_titulo')}>
    <div class="lab-modal">

      <div class="lab-modal-header">
        <div class="lab-modal-header-izq">
          <IconoSVG nombre="candado" tamaño={28} grosor={1.4} />
          <h3 class="lab-modal-titulo">{t(lang, 'lab_modal_pass_titulo')}</h3>
        </div>
        <button class="lab-modal-cerrar" aria-label={t(lang, 'lab_modal_cerrar_aria')}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="lab-modal-body">
        <div class="lab-modal-grid">

          <!-- Columna izquierda: modos + descripción -->
          <div class="lab-modal-grid-col">
            <div class="gen-modos">
              <button class="gen-modo activo" data-modo="segura">
                <span class="gen-modo-nombre">{t(lang, 'lab_pass_modo_segura')}</span>
                <span class="gen-modo-desc">{t(lang, 'lab_pass_modo_segura_desc')}</span>
              </button>
              <button class="gen-modo" data-modo="pro">
                <span class="gen-modo-nombre">{t(lang, 'lab_pass_modo_pro')}</span>
                <span class="gen-modo-desc">{t(lang, 'lab_pass_modo_pro_desc')}</span>
              </button>
              <button class="gen-modo" data-modo="ultra">
                <span class="gen-modo-nombre">{t(lang, 'lab_pass_modo_ultra')}</span>
                <span class="gen-modo-desc">{t(lang, 'lab_pass_modo_ultra_desc')}</span>
              </button>
            </div>
            <div class="gen-modo-info" id="gen-modo-info">
              <p class="gen-modo-info-texto" id="gen-modo-info-segura">{t(lang, 'lab_pass_info_segura')}</p>
              <p class="gen-modo-info-texto" id="gen-modo-info-pro" style="display:none">{t(lang, 'lab_pass_info_pro')}</p>
              <p class="gen-modo-info-texto" id="gen-modo-info-ultra" style="display:none">{t(lang, 'lab_pass_info_ultra')}</p>
            </div>
          </div>

          <!-- Columna derecha: controles -->
          <div class="lab-modal-grid-col">
            <div class="gen-controles" id="gen-controles">
              <div class="gen-control">
                <div class="gen-control-label">
                  <span>{t(lang, 'lab_pass_largo')}</span>
                  <span class="gen-control-valor" id="gen-largo-valor">16</span>
                </div>
                <input type="range" id="gen-largo" min="8" max="64" value="16" class="gen-slider" />
                <div class="gen-presets">
                  <button class="gen-preset" data-largo="12">12</button>
                  <button class="gen-preset activo" data-largo="16">16</button>
                  <button class="gen-preset" data-largo="20">20</button>
                  <button class="gen-preset" data-largo="24">24</button>
                  <button class="gen-preset" data-largo="32">32</button>
                </div>
              </div>
              <div class="gen-opciones-custom" id="gen-opciones-pro" style="display:none">
                <div class="gen-toggles">
                  <label class="gen-toggle">
                    <input type="checkbox" id="gen-mayusculas" checked />
                    <span class="gen-toggle-switch"></span>
                    <span class="gen-toggle-label">{t(lang, 'lab_pass_mayusculas')}</span>
                    <span class="gen-toggle-ejemplo">A-Z</span>
                  </label>
                  <label class="gen-toggle">
                    <input type="checkbox" id="gen-minusculas" checked />
                    <span class="gen-toggle-switch"></span>
                    <span class="gen-toggle-label">{t(lang, 'lab_pass_minusculas')}</span>
                    <span class="gen-toggle-ejemplo">a-z</span>
                  </label>
                  <label class="gen-toggle">
                    <input type="checkbox" id="gen-numeros" checked />
                    <span class="gen-toggle-switch"></span>
                    <span class="gen-toggle-label">{t(lang, 'lab_pass_numeros')}</span>
                    <span class="gen-toggle-ejemplo">0-9</span>
                  </label>
                  <label class="gen-toggle">
                    <input type="checkbox" id="gen-simbolos" checked />
                    <span class="gen-toggle-switch"></span>
                    <span class="gen-toggle-label">{t(lang, 'lab_pass_simbolos')}</span>
                    <span class="gen-toggle-ejemplo">!@#$</span>
                  </label>
                  <label class="gen-toggle">
                    <input type="checkbox" id="gen-guiones" checked />
                    <span class="gen-toggle-switch"></span>
                    <span class="gen-toggle-label">{t(lang, 'lab_pass_guiones')}</span>
                    <span class="gen-toggle-ejemplo">xxxx-xxxx</span>
                  </label>
                </div>
              </div>
              <div id="gen-info-ultra" style="display:none"></div>
            </div>
          </div>

          <!-- Full-width: resultado + fuerza -->
          <div class="lab-modal-grid-full">
            <div class="gen-resultado">
              <input type="text" class="gen-password" id="gen-password" value="" placeholder={t(lang, 'lab_pass_placeholder')} spellcheck="false" autocomplete="off" />
              <button class="gen-copiar" id="gen-copiar" aria-label={t(lang, 'lab_pass_copiar_aria')} title={t(lang, 'lab_qr_copiar_btn')}>
                <svg class="gen-copiar-icono" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="gen-copiar-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
              </button>
            </div>
            <div class="gen-fuerza">
              <div class="gen-fuerza-barra">
                <div class="gen-fuerza-nivel" id="gen-fuerza-nivel"></div>
              </div>
              <span class="gen-fuerza-texto" id="gen-fuerza-texto">—</span>
            </div>
          </div>

        </div>
      </div>

      <!-- Footer fijo con botón generar -->
      <div class="lab-modal-footer">
        <button class="gen-boton" id="gen-generar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.78 7.78 5.5 5.5 0 0 1 7.78-7.78zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
          {t(lang, 'lab_pass_generar_btn')}
        </button>
      </div>

    </div>
  </div>

  <!-- ============================================================
       MODAL: Generador de Códigos QR
       ============================================================ -->
  <div class="lab-modal-overlay" id="modal-qr" aria-hidden="true" role="dialog" aria-modal="true" aria-label={t(lang, 'lab_modal_qr_titulo')}>
    <div class="lab-modal lab-modal--ancho">

      <div class="lab-modal-header">
        <div class="lab-modal-header-izq">
          <IconoSVG nombre="qr" tamaño={28} grosor={1.4} />
          <h3 class="lab-modal-titulo">{t(lang, 'lab_modal_qr_titulo')}</h3>
        </div>
        <button class="lab-modal-cerrar" aria-label={t(lang, 'lab_modal_cerrar_aria')}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="lab-modal-body">
        <div class="lab-modal-grid">

          <!-- Columna izquierda: preview QR -->
          <div class="lab-modal-grid-col lab-modal-grid-col--centro">
            <div class="qr-preview-zona">
              <div class="qr-preview" id="qr-preview">
                <canvas id="qr-canvas" width="280" height="280"></canvas>
              </div>
            </div>
          </div>

          <!-- Columna derecha: opciones -->
          <div class="lab-modal-grid-col">
            <div class="qr-campo">
              <label class="qr-label" for="qr-url">{t(lang, 'lab_qr_url_label')}</label>
              <input type="text" class="qr-input" id="qr-url" placeholder={t(lang, 'lab_qr_url_placeholder')} spellcheck="false" autocomplete="off" value="https://stiancode.dev" />
            </div>

            <div class="qr-seccion">
              <span class="qr-label">{t(lang, 'lab_qr_fondo')}</span>
              <div class="qr-opciones-fondo">
                <button class="qr-opcion-fondo activo" data-fondo="transparente">
                  <span class="qr-fondo-muestra qr-fondo-transparente"></span>
                  <span>{t(lang, 'lab_qr_fondo_transparente')}</span>
                </button>
                <button class="qr-opcion-fondo" data-fondo="blanco">
                  <span class="qr-fondo-muestra" style="background:#fff"></span>
                  <span>{t(lang, 'lab_qr_fondo_blanco')}</span>
                </button>
                <button class="qr-opcion-fondo" data-fondo="negro">
                  <span class="qr-fondo-muestra" style="background:#111"></span>
                  <span>{t(lang, 'lab_qr_fondo_negro')}</span>
                </button>
                <button class="qr-opcion-fondo" data-fondo="custom">
                  <span class="qr-fondo-muestra" style="background:var(--acento)"></span>
                  <span>{t(lang, 'lab_qr_fondo_color')}</span>
                </button>
              </div>
              <div class="qr-color-custom" id="qr-fondo-custom" style="display:none">
                <span class="qr-color-label">{t(lang, 'lab_qr_color_fondo_label')}</span>
                <input type="color" id="qr-fondo-color" value="#7c5ce8" class="qr-color-picker" />
                <input type="text" id="qr-fondo-hex" value="#7c5ce8" class="qr-hex-input" maxlength="7" spellcheck="false" placeholder="#7c5ce8" />
              </div>
            </div>

            <div class="qr-seccion">
              <span class="qr-label">{t(lang, 'lab_qr_color_codigo')}</span>
              <div class="qr-colores-rapidos">
                <button class="qr-color-btn activo" data-color="#000000" style="background:#000;border-color:#333"></button>
                <button class="qr-color-btn" data-color="#ffffff" style="background:#fff"></button>
                <button class="qr-color-btn" data-color="#7c5ce8" style="background:#7c5ce8"></button>
                <button class="qr-color-btn" data-color="#3b82f6" style="background:#3b82f6"></button>
                <button class="qr-color-btn" data-color="#10b981" style="background:#10b981"></button>
                <button class="qr-color-btn" data-color="#ef4444" style="background:#ef4444"></button>
              </div>
              <div class="qr-color-row">
                <input type="color" id="qr-dot-color" value="#000000" class="qr-color-picker" title={t(lang, 'lab_qr_elegir_color')} />
                <input type="text" id="qr-dot-hex" value="#000000" class="qr-hex-input" maxlength="7" spellcheck="false" placeholder="#000000" />
              </div>
            </div>

            <div class="qr-seccion">
              <div class="qr-toggle-row">
                <label class="gen-toggle">
                  <input type="checkbox" id="qr-logo-toggle" checked />
                  <span class="gen-toggle-switch"></span>
                  <span class="gen-toggle-label">{t(lang, 'lab_qr_logo_centro')}</span>
                </label>
              </div>
              <div class="qr-logo-opciones" id="qr-logo-opciones">
                <button class="qr-logo-btn activo" id="qr-logo-sitio" data-logo="sitio">{t(lang, 'lab_qr_logo_sitio')}</button>
                <label class="qr-logo-btn" id="qr-logo-custom-label" data-logo="custom">
                  {t(lang, 'lab_qr_subir_imagen')}
                  <input type="file" id="qr-logo-file" accept="image/*" style="display:none" />
                </label>
              </div>
            </div>

            <div class="qr-seccion">
              <div class="gen-control-label">
                <span class="qr-label">{t(lang, 'lab_qr_tamano_descarga')}</span>
                <span class="gen-control-valor" id="qr-tamano-valor">512px</span>
              </div>
              <input type="range" id="qr-tamano" min="256" max="1024" step="128" value="512" class="gen-slider" />
            </div>
          </div>

        </div>
      </div>

      <!-- Footer fijo -->
      <div class="lab-modal-footer qr-footer">
        <button class="qr-accion-btn" id="qr-copiar">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          {t(lang, 'lab_qr_copiar_btn')}
        </button>
        <button class="gen-boton" id="qr-descargar">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          {t(lang, 'lab_qr_descargar_btn')}
        </button>
      </div>

    </div>
  </div>

  <!-- ============================================================
       MODAL: Generador QR Wi-Fi
       ============================================================ -->
  <div class="lab-modal-overlay" id="modal-wifi" aria-hidden="true" role="dialog" aria-modal="true" aria-label={t(lang, 'lab_modal_wifi_titulo')}>
    <div class="lab-modal lab-modal--wifi">

      <div class="lab-modal-header">
        <div class="lab-modal-header-izq">
          <IconoSVG nombre="wifi" tamaño={28} grosor={1.4} />
          <h3 class="lab-modal-titulo">{t(lang, 'lab_modal_wifi_titulo')}</h3>
        </div>
        <button class="lab-modal-cerrar" aria-label={t(lang, 'lab_modal_cerrar_aria')}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="lab-modal-body">
        <div class="lab-modal-grid lab-modal-grid--tres">

          <!-- Col 1: Datos de red -->
          <div class="lab-modal-grid-col">
            <div class="qr-campo">
              <label class="qr-label" for="wifi-ssid">{t(lang, 'lab_wifi_ssid_label')}</label>
              <input type="text" class="qr-input" id="wifi-ssid" placeholder={t(lang, 'lab_wifi_ssid_placeholder')} spellcheck="false" autocomplete="off" />
            </div>

            <div class="qr-campo">
              <label class="qr-label" for="wifi-pass">{t(lang, 'lab_wifi_pass_label')}</label>
              <div class="wifi-pass-row">
                <input type="password" class="qr-input wifi-pass-input" id="wifi-pass" placeholder="••••••••" spellcheck="false" autocomplete="off" />
                <button class="wifi-pass-toggle" id="wifi-pass-toggle" aria-label={t(lang, 'lab_wifi_mostrar_pass')} type="button">
                  <svg class="wifi-eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  <svg class="wifi-eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                </button>
              </div>
            </div>

            <div class="qr-seccion">
              <span class="qr-label">{t(lang, 'lab_wifi_seguridad')}</span>
              <div class="wifi-seguridad">
                <button class="wifi-seg-btn activo" data-seg="WPA">WPA/WPA2</button>
                <button class="wifi-seg-btn" data-seg="WEP">WEP</button>
                <button class="wifi-seg-btn" data-seg="nopass">{t(lang, 'lab_wifi_sin_pass')}</button>
              </div>
            </div>

            <div class="qr-seccion">
              <label class="gen-toggle">
                <input type="checkbox" id="wifi-oculta" />
                <span class="gen-toggle-switch"></span>
                <span class="gen-toggle-label">{t(lang, 'lab_wifi_red_oculta')}</span>
              </label>
            </div>
          </div>

          <!-- Col 2: Preview QR -->
          <div class="lab-modal-grid-col lab-modal-grid-col--centro">
            <div class="qr-preview-zona">
              <div class="qr-preview" id="wifi-qr-preview">
                <canvas id="wifi-canvas" width="280" height="280"></canvas>
              </div>
            </div>
          </div>

          <!-- Col 3: Estilos -->
          <div class="lab-modal-grid-col">
            <div class="qr-seccion">
              <span class="qr-label">{t(lang, 'lab_qr_fondo')}</span>
              <div class="qr-opciones-fondo">
                <button class="qr-opcion-fondo wifi-fondo-btn activo" data-fondo="transparente">
                  <span class="qr-fondo-muestra qr-fondo-transparente"></span>
                  <span>{t(lang, 'lab_qr_fondo_transparente')}</span>
                </button>
                <button class="qr-opcion-fondo wifi-fondo-btn" data-fondo="blanco">
                  <span class="qr-fondo-muestra" style="background:#fff"></span>
                  <span>{t(lang, 'lab_qr_fondo_blanco')}</span>
                </button>
                <button class="qr-opcion-fondo wifi-fondo-btn" data-fondo="negro">
                  <span class="qr-fondo-muestra" style="background:#111"></span>
                  <span>{t(lang, 'lab_qr_fondo_negro')}</span>
                </button>
                <button class="qr-opcion-fondo wifi-fondo-btn" data-fondo="custom">
