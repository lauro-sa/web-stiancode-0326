    // --- Calcular crop con pan ---
    function rdsCalcCrop(imgW: number, imgH: number, tW: number, tH: number) {
      const srcRatio = imgW / imgH;
      const dstRatio = tW / tH;
      let sw = imgW, sh = imgH, sx = 0, sy = 0;
      if (srcRatio > dstRatio) {
        // Imagen más ancha: recortar horizontalmente
        sw = imgH * dstRatio;
        const maxOffset = imgW - sw;
        sx = maxOffset * rdsPanX;
      } else {
        // Imagen más alta: recortar verticalmente
        sh = imgW / dstRatio;
        const maxOffset = imgH - sh;
        sy = maxOffset * rdsPanY;
      }
      return { sx, sy, sw, sh };
    }

    // --- Cargar imagen ---
    function rdsCargarArchivo(file: File) {
      if (!file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          rdsImagen = img;
          rdsPanX = 0.5;
          rdsPanY = 0.5;
          rdsDropzone.style.display = 'none';
          rdsPreviewZona.style.display = '';
          rdsDescargar.disabled = false;
          rdsRenderPreview();
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(file);
    }

    // --- Render preview ---
    function rdsRenderPreview() {
      if (!rdsImagen) return;
      const ctx = rdsCanvas.getContext('2d');
      if (!ctx) return;

      const maxPreviewW = 360;
      const ratio = rdsTargetW / rdsTargetH;
      let prevW = maxPreviewW;
      let prevH = prevW / ratio;
      if (prevH > 340) { prevH = 340; prevW = prevH * ratio; }

      rdsCanvas.width = prevW;
      rdsCanvas.height = prevH;

      const { sx, sy, sw, sh } = rdsCalcCrop(rdsImagen.width, rdsImagen.height, rdsTargetW, rdsTargetH);

      ctx.clearRect(0, 0, prevW, prevH);
      ctx.drawImage(rdsImagen, sx, sy, sw, sh, 0, 0, prevW, prevH);

      rdsDims.textContent = `${rdsTargetW} × ${rdsTargetH} px`;
      rdsAnchoInput.value = String(rdsTargetW);
      rdsAltoInput.value = String(rdsTargetH);
    }

    // --- Drag para reposicionar imagen ---
    let rdsDragging = false;
    let rdsDragStartX = 0;
    let rdsDragStartY = 0;
    let rdsPanStartX = 0;
    let rdsPanStartY = 0;

    rdsCanvas.style.cursor = 'grab';

    rdsCanvas.addEventListener('mousedown', (e) => {
      if (!rdsImagen) return;
      rdsDragging = true;
      rdsDragStartX = e.clientX;
      rdsDragStartY = e.clientY;
      rdsPanStartX = rdsPanX;
      rdsPanStartY = rdsPanY;
      rdsCanvas.style.cursor = 'grabbing';
    });

    window.addEventListener('mousemove', (e) => {
      if (!rdsDragging || !rdsImagen) return;
      const dx = e.clientX - rdsDragStartX;
      const dy = e.clientY - rdsDragStartY;
      // Sensibilidad: mover 200px = recorrer todo el rango
      const sensitivity = 200;
      rdsPanX = Math.max(0, Math.min(1, rdsPanStartX - dx / sensitivity));
      rdsPanY = Math.max(0, Math.min(1, rdsPanStartY - dy / sensitivity));
      rdsRenderPreview();
    });

    window.addEventListener('mouseup', () => {
      if (rdsDragging) {
        rdsDragging = false;
        rdsCanvas.style.cursor = 'grab';
      }
    });

    // Touch para mobile
    rdsCanvas.addEventListener('touchstart', (e) => {
      if (!rdsImagen) return;
      rdsDragging = true;
      const t = e.touches[0];
      rdsDragStartX = t.clientX;
      rdsDragStartY = t.clientY;
      rdsPanStartX = rdsPanX;
      rdsPanStartY = rdsPanY;
    }, { passive: true });

    window.addEventListener('touchmove', (e) => {
      if (!rdsDragging || !rdsImagen) return;
      const t = e.touches[0];
      const dx = t.clientX - rdsDragStartX;
      const dy = t.clientY - rdsDragStartY;
      const sensitivity = 200;
      rdsPanX = Math.max(0, Math.min(1, rdsPanStartX - dx / sensitivity));
      rdsPanY = Math.max(0, Math.min(1, rdsPanStartY - dy / sensitivity));
      rdsRenderPreview();
    }, { passive: true });

    window.addEventListener('touchend', () => { rdsDragging = false; });

    // --- Generar imagen final para descarga ---
    function rdsGenerarBlob(): Promise<Blob | null> {
      return new Promise((resolve) => {
        if (!rdsImagen) { resolve(null); return; }
        const offscreen = document.createElement('canvas');
        offscreen.width = rdsTargetW;
        offscreen.height = rdsTargetH;
        const ctx = offscreen.getContext('2d');
        if (!ctx) { resolve(null); return; }

        const { sx, sy, sw, sh } = rdsCalcCrop(rdsImagen.width, rdsImagen.height, rdsTargetW, rdsTargetH);
        ctx.drawImage(rdsImagen, sx, sy, sw, sh, 0, 0, rdsTargetW, rdsTargetH);

        const mimeType = `image/${rdsFormato}`;
        const quality = rdsFormato === 'png' ? undefined : parseInt(rdsCalidad.value) / 100;
        offscreen.toBlob((blob) => resolve(blob), mimeType, quality);
      });
    }

    // --- Eventos: dropzone ---
    rdsDropzone.addEventListener('click', () => rdsFileInput.click());
    rdsFileInput.addEventListener('change', () => {
      if (rdsFileInput.files?.[0]) rdsCargarArchivo(rdsFileInput.files[0]);
    });

    rdsDropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      rdsDropzone.classList.add('rds-drag');
    });
    rdsDropzone.addEventListener('dragleave', () => rdsDropzone.classList.remove('rds-drag'));
    rdsDropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      rdsDropzone.classList.remove('rds-drag');
      if (e.dataTransfer?.files?.[0]) rdsCargarArchivo(e.dataTransfer.files[0]);
    });

    // --- Evento: cambiar imagen ---
    rdsCambiar.addEventListener('click', () => {
      rdsImagen = null;
      rdsFileInput.value = '';
      rdsDropzone.style.display = '';
      rdsPreviewZona.style.display = 'none';
      rdsDescargar.disabled = true;
    });

    // --- Eventos: presets ---
    document.querySelectorAll('.rds-preset').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.rds-preset').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        const el = btn as HTMLElement;
        rdsTargetW = parseInt(el.dataset.w || '1080');
        rdsTargetH = parseInt(el.dataset.h || '1080');
        rdsNombrePreset = el.dataset.nombre || 'Imagen';
        rdsPanX = 0.5; rdsPanY = 0.5;
        rdsRenderPreview();
      });
    });

    // --- Evento: personalizado ---
    rdsAplicar.addEventListener('click', () => {
      const w = parseInt(rdsAnchoInput.value);
      const h = parseInt(rdsAltoInput.value);
      if (w > 0 && h > 0 && w <= 4096 && h <= 4096) {
        rdsTargetW = w;
        rdsTargetH = h;
        rdsNombrePreset = _t.personalizado || 'Custom';
        rdsPanX = 0.5; rdsPanY = 0.5;
        document.querySelectorAll('.rds-preset').forEach(b => b.classList.remove('activo'));
        rdsRenderPreview();
      }
    });

    // --- Eventos: formato ---
    document.querySelectorAll('.rds-formato').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.rds-formato').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        rdsFormato = (btn as HTMLElement).dataset.fmt || 'jpeg';
        // Mostrar/ocultar calidad (no aplica a PNG)
        rdsCalidadZona.style.display = rdsFormato === 'png' ? 'none' : '';
      });
    });

    // --- Evento: calidad slider ---
    function rdsActualizarCalidad() {
      const val = parseInt(rdsCalidad.value);
      rdsCalidadValor.textContent = `${val}%`;
      let color = '#10b981'; // verde
      let label = _t.calidad_alta || 'High';
      if (val < 50) { color = '#ef4444'; label = _t.calidad_baja || 'Low'; }
      else if (val < 75) { color = '#f59e0b'; label = _t.calidad_media || 'Medium'; }
      rdsCalidadValor.style.color = color;
      rdsCalidadValor.textContent = `${val}% · ${label}`;
    }
    rdsCalidad.addEventListener('input', rdsActualizarCalidad);
    rdsActualizarCalidad();

    // --- Evento: descargar ---
    rdsDescargar.addEventListener('click', async () => {
      const blob = await rdsGenerarBlob();
      if (!blob) return;
      const ext = rdsFormato === 'jpeg' ? 'jpg' : rdsFormato;
      const nombre = rdsNombrePreset.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${nombre}-${rdsTargetW}x${rdsTargetH}.${ext}`;
      a.click();
      URL.revokeObjectURL(url);
    });

    } catch (err) {
      console.error('Error inicializando herramientas:', err);
    }
  });
</script>

