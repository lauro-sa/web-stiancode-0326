---
// ============================================================
// about.astro — "About me" page with timeline (English)
// ============================================================
import { t } from '../../i18n/utils.js';
import Plantilla from '../../layouts/Plantilla.astro';
import Nav       from '../../components/Nav.astro';
import Footer    from '../../components/Footer.astro';
import Boton     from '../../components/Boton.astro';

const lang = 'en';

const EVENTOS = [
  { anio: t(lang, 'sobre_pagina_evento_01_anio'), tipo: t(lang, 'sobre_pagina_evento_01_tipo'), titulo: t(lang, 'sobre_pagina_evento_01_titulo'), descripcion: t(lang, 'sobre_pagina_evento_01_desc') },
  { anio: t(lang, 'sobre_pagina_evento_02_anio'), tipo: t(lang, 'sobre_pagina_evento_02_tipo'), titulo: t(lang, 'sobre_pagina_evento_02_titulo'), descripcion: t(lang, 'sobre_pagina_evento_02_desc') },
  { anio: t(lang, 'sobre_pagina_evento_03_anio'), tipo: t(lang, 'sobre_pagina_evento_03_tipo'), titulo: t(lang, 'sobre_pagina_evento_03_titulo'), descripcion: t(lang, 'sobre_pagina_evento_03_desc') },
  { anio: t(lang, 'sobre_pagina_evento_04_anio'), tipo: t(lang, 'sobre_pagina_evento_04_tipo'), titulo: t(lang, 'sobre_pagina_evento_04_titulo'), descripcion: t(lang, 'sobre_pagina_evento_04_desc') },
  { anio: t(lang, 'sobre_pagina_evento_05_anio'), tipo: t(lang, 'sobre_pagina_evento_05_tipo'), titulo: t(lang, 'sobre_pagina_evento_05_titulo'), descripcion: t(lang, 'sobre_pagina_evento_05_desc') },
  { anio: t(lang, 'sobre_pagina_evento_06_anio'), tipo: t(lang, 'sobre_pagina_evento_06_tipo'), titulo: t(lang, 'sobre_pagina_evento_06_titulo'), descripcion: t(lang, 'sobre_pagina_evento_06_desc') },
  { anio: t(lang, 'sobre_pagina_evento_07_anio'), tipo: t(lang, 'sobre_pagina_evento_07_tipo'), titulo: t(lang, 'sobre_pagina_evento_07_titulo'), descripcion: t(lang, 'sobre_pagina_evento_07_desc') },
  { anio: t(lang, 'sobre_pagina_evento_08_anio'), tipo: t(lang, 'sobre_pagina_evento_08_tipo'), titulo: t(lang, 'sobre_pagina_evento_08_titulo'), descripcion: t(lang, 'sobre_pagina_evento_08_desc') },
  { anio: t(lang, 'sobre_pagina_evento_09_anio'), tipo: t(lang, 'sobre_pagina_evento_09_tipo'), titulo: t(lang, 'sobre_pagina_evento_09_titulo'), descripcion: t(lang, 'sobre_pagina_evento_09_desc') },
  { anio: t(lang, 'sobre_pagina_evento_10_anio'), tipo: t(lang, 'sobre_pagina_evento_10_tipo'), titulo: t(lang, 'sobre_pagina_evento_10_titulo'), descripcion: t(lang, 'sobre_pagina_evento_10_desc') },
  { anio: t(lang, 'sobre_pagina_evento_11_anio'), tipo: t(lang, 'sobre_pagina_evento_11_tipo'), titulo: t(lang, 'sobre_pagina_evento_11_titulo'), descripcion: t(lang, 'sobre_pagina_evento_11_desc') },
];
---

<Plantilla
  titulo={t(lang, 'pagina_sobre_titulo')}
  descripcion={t(lang, 'pagina_sobre_desc')}
  lang={lang}
>
  <Nav lang={lang}/>

  <main>
    <div class="fondo-puntos">
      <section class="seccion sobre-pagina">

        <!-- Presentación -->
        <div class="sobre-presentacion">
          <div class="sobre-foto-col">
            <div class="sobre-foto-wrapper">
              <img src="/perfil.png" alt="Sebastián" class="sobre-foto" width="220" height="220" />
            </div>
            <span class="sobre-rol">{t(lang, 'sobre_pagina_rol')}</span>
            <span class="sobre-periodo">{t(lang, 'sobre_pagina_periodo')}</span>
          </div>

          <div class="sobre-info-col">
            <span class="etiqueta">{t(lang, 'sobre_pagina_etiqueta')}</span>
            <h1 class="titulo-dos-tonos">
              <span class="negro">{t(lang, 'sobre_pagina_titulo_negro')}</span><br>
              <span class="gris">{t(lang, 'sobre_pagina_titulo_gris')}</span>
            </h1>
            <p class="sobre-bio-texto">
              {t(lang, 'sobre_pagina_bio_1')}
            </p>
            <p class="sobre-bio-texto">
              {t(lang, 'sobre_pagina_bio_2')}
            </p>
          </div>
        </div>

        <!-- Título línea de tiempo -->
        <div class="timeline-heading">
          <span class="etiqueta">{t(lang, 'sobre_pagina_trayectoria')}</span>
          <h2 class="timeline-subtitulo">{t(lang, 'sobre_pagina_timeline_sub')}</h2>
        </div>

        <!-- Línea de tiempo -->
        <div class="timeline">
          <div class="timeline-linea"></div>
          {EVENTOS.map((evento, i) => (
            <div class="timeline-item" style={`--delay: ${i * 0.08}s`}>
              <div class="timeline-punto"></div>
              <div class="timeline-contenido">
                <div class="timeline-cabecera">
                  <span class="timeline-anio">{evento.anio}</span>
                  <span class={`timeline-tipo ${evento.tipo === 'Proyecto' || evento.tipo === 'Project' ? 'tipo-proyecto' : 'tipo-formacion'}`}>
                    {evento.tipo}
                  </span>
                </div>
                <h3 class="timeline-titulo">{evento.titulo}</h3>
                <p class="timeline-desc">{evento.descripcion}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Botón volver -->
        <div class="sobre-volver">
          <Boton variante="fantasma" href={lang === 'en' ? '/en/' : '/'}>
            {t(lang, 'volver_inicio')}
          </Boton>
        </div>

      </section>
    </div>
  </main>

  <Footer lang={lang}/>
</Plantilla>

<style>
  .sobre-pagina {
    padding-top: clamp(120px, 15vw, 180px);
  }

  /* ---- Presentación ---- */
  .sobre-presentacion {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 72px;
  }

  .sobre-foto-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 24px;
    border: 1px solid var(--borde);
    border-radius: var(--radio-card);
    transition: border-color var(--transicion);
  }

  .sobre-foto-wrapper {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--gradiente);
    padding: 3px;
  }

  .sobre-foto {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .sobre-rol {
    font-size: 14px;
    font-weight: 600;
    color: var(--texto);
    transition: color var(--transicion);
  }

  .sobre-periodo {
    font-size: 13px;
    color: var(--gris-sub);
    transition: color var(--transicion);
  }

  .sobre-info-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sobre-bio-texto {
    font-size: 15px;
    color: var(--gris-sub);
    line-height: 1.8;
    transition: color var(--transicion);
  }

  .timeline-heading {
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .timeline-subtitulo {
    font-size: 18px;
    font-weight: 500;
    color: var(--gris-sub);
    transition: color var(--transicion);
  }

  /* ---- Línea de tiempo ---- */
  .timeline {
    position: relative;
    padding-left: 32px;
  }

  .timeline-linea {
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--borde);
    transition: background var(--transicion);
  }

  /* Cada evento */
  .timeline-item {
    position: relative;
    padding-bottom: 48px;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease var(--delay), transform 0.6s ease var(--delay);
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Punto en la línea */
  .timeline-punto {
    position: absolute;
    left: -29px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--fondo);
    border: 2px solid var(--acento);
    transition: background var(--transicion), border-color var(--transicion), transform 0.3s, box-shadow 0.3s;
    z-index: 2;
  }

  .timeline-item:hover .timeline-punto {
    transform: scale(1.3);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--acento) 20%, transparent);
  }

  /* Contenido */
  .timeline-contenido {
    padding: 20px 24px;
    background: var(--card);
    border: 1px solid var(--borde);
    border-radius: var(--radio-card);
    transition: background var(--transicion), border-color var(--transicion), transform 0.3s;
  }

  .timeline-contenido:hover {
    transform: translateX(4px);
  }

  .timeline-cabecera {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .timeline-anio {
    font-size: 13px;
    font-weight: 600;
    color: var(--acento);
  }

  .timeline-tipo {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: var(--radio-pill);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .tipo-formacion {
    background: color-mix(in srgb, var(--acento) 12%, transparent);
    color: var(--acento);
  }

  .tipo-proyecto {
    background: color-mix(in srgb, var(--acento-alt) 12%, transparent);
    color: var(--acento-alt);
  }

  .timeline-titulo {
    font-size: 17px;
    font-weight: 600;
    color: var(--texto);
    margin-bottom: 6px;
    transition: color var(--transicion);
  }

  .timeline-desc {
    font-size: 14px;
    color: var(--gris-sub);
    line-height: 1.7;
    transition: color var(--transicion);
  }

  .sobre-volver {
    margin-top: 48px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .sobre-presentacion { grid-template-columns: 1fr; justify-items: center; text-align: center; }
    .sobre-info-col { align-items: center; }
  }

  @media (max-width: 600px) {
    .timeline { padding-left: 24px; }
    .timeline-punto { left: -21px; width: 10px; height: 10px; }
    .timeline-linea { left: 5px; }
    .timeline-contenido { padding: 16px 18px; }
    .sobre-foto-wrapper { width: 140px; height: 140px; }
  }
</style>

<script>
  // Animación al hacer scroll: los items aparecen al entrar en el viewport
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.timeline-item');
    if (!items.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    items.forEach((item) => observer.observe(item));
  });
</script>
