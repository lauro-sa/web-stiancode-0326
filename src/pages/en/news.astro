<Plantilla
  titulo={t(lang, 'pagina_noticias_titulo')}
  descripcion={t(lang, 'pagina_noticias_desc')}
  lang={lang}
>
  <Nav lang={lang}/>

  <main>
    <div class="fondo-puntos">
      <div class="panel-interior">
        <section class="seccion" id="novedades">

          <span class="etiqueta">{t(lang, 'noticias_etiqueta')}</span>
          <h2 class="titulo-dos-tonos">
            <span class="negro">{t(lang, 'noticias_titulo_negro')}</span><br>
            <span class="gris">{t(lang, 'noticias_titulo_gris')}</span>
          </h2>
          <p class="typewriter" data-texto={t(lang, 'noticias_subtitulo')} aria-label={t(lang, 'noticias_subtitulo')}></p>

          <!-- Filtros -->
          <div class="nv-filtros">
            {categorias.map((cat) => (
              <button class={`nv-filtro ${cat === 'Todos' ? 'activo' : ''}`} data-cat={cat.toLowerCase()}>
                {cat}
              </button>
            ))}
          </div>

          <!-- Semanas -->
          {semanas.length === 0 ? (
            <div class="nv-vacio">
              <p>{t(lang, 'noticias_vacio')}</p>
            </div>
          ) : (
            semanas.map((semana) => (
              <div class="nv-semana" data-semana={semana.clave}>

                <div class="nv-semana-header">
                  <div class="nv-semana-izq">
                    {semana.esActual && <span class="nv-badge">{t(lang, 'noticias_esta_semana')}</span>}
                    <h3 class="nv-semana-rango">{semana.rango}</h3>
                  </div>
                  <span class="nv-semana-count">{semana.articulos.length} {t(lang, 'noticias_articulos')}</span>
                </div>

                <div class="nv-lista">
                  {semana.articulos.map((art) => (
                    <div class="nv-item" data-cat={art.categoria.toLowerCase()}>

                      {/* --- HEADER: siempre visible --- */}
                      <button class="nv-item-btn" aria-expanded="false">
                        <div class="nv-item-texto">
                          <div class="nv-item-meta">
                            <span class="nv-item-cat">{art.categoria}</span>
                            <span class="nv-item-fuente">{art.fuente}</span>
                            <span class="nv-item-sep">·</span>
                            <span class="nv-item-fecha">
                              {art.fecha.toLocaleDateString('es-AR', { day: 'numeric', month: 'short' })}
                            </span>
                            <span class="nv-item-sep">·</span>
                            <span class="nv-item-lectura">{art.minLectura} {t(lang, 'noticias_min_lectura')}</span>
                          </div>
                          <h4 class="nv-item-titulo">{art.titulo}</h4>
                          <p class="nv-item-preview">{art.descripcion.slice(0, 110)}...</p>
                        </div>
                        {art.imagen && (
                          <div class="nv-item-thumb">
                            <img src={art.imagen} alt={art.titulo} loading="lazy" />
                          </div>
                        )}
                        <svg class="nv-item-flecha" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                      </button>

                      {/* --- CUERPO: expandible --- */}
                      <div class="nv-item-cuerpo">
                        <div class="nv-item-expandido">
                          {art.imagen && (
                            <img class="nv-item-img-grande" src={art.imagen} alt={art.titulo} loading="lazy" />
                          )}
                          <p class="nv-item-desc">{art.descripcion}</p>
                          <a class="nv-item-link" href={art.url} target="_blank" rel="noopener noreferrer">
                            {t(lang, 'noticias_ir_noticia')}
                          </a>
                        </div>
                      </div>

                    </div>
                  ))}
                </div>

              </div>
            ))
          )}

          {/* ============================================================
              TIMELINE — Lo más fuerte de cada mes
              ============================================================ */}
          <div class="tl-seccion">
            <div class="tl-header">
              <h3 class="tl-titulo">
                <span class="negro">{t(lang, 'noticias_timeline_negro')}</span>
                <span class="gris">{t(lang, 'noticias_timeline_gris')}</span>
              </h3>
              <p class="tl-sub">{t(lang, 'noticias_timeline_sub')}</p>
            </div>

            <div class="tl-linea">
              {TIMELINE.map((mes) => (
                <div class="tl-mes">
                  <div class="tl-mes-marker">
                    <div class="tl-mes-punto"></div>
                    <div class="tl-mes-linea"></div>
                  </div>
                  <div class="tl-mes-contenido">
                    <h4 class="tl-mes-nombre">{mes.mes}</h4>
                    {mes.noticias.map((n) => (
                      <div class="tl-noticia">
                        <span class="tl-noticia-tag">{n.tag}</span>
                        <h5 class="tl-noticia-titulo">{n.titulo}</h5>
                        <p class="tl-noticia-desc">{n.descripcion}</p>
                        {n.url && (
                          <a class="tl-noticia-link" href={n.url} target="_blank" rel="noopener noreferrer">
                            {t(lang, 'noticias_ver_mas')}
                          </a>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="nv-volver">
            <Boton variante="fantasma" href={lang === 'en' ? '/en/' : '/#noticias'}>{t(lang, 'volver_inicio')}</Boton>
          </div>

        </section>
      </div>
    </div>
  </main>

  <Footer lang={lang}/>
</Plantilla>

<script>
  document.addEventListener('DOMContentLoaded', () => {

    // --- Acordeón: solo uno abierto a la vez ---
    const todosItems = document.querySelectorAll('.nv-item');

    function cerrarItem(item: Element) {
      const cuerpo = item.querySelector('.nv-item-cuerpo') as HTMLElement;
      const btn = item.querySelector('.nv-item-btn') as HTMLElement;
      if (!cuerpo || !btn) return;
      cuerpo.style.maxHeight = '0';
      item.classList.remove('abierto');
      btn.setAttribute('aria-expanded', 'false');
    }

    function abrirItem(item: Element) {
      const cuerpo = item.querySelector('.nv-item-cuerpo') as HTMLElement;
      const btn = item.querySelector('.nv-item-btn') as HTMLElement;
      if (!cuerpo || !btn) return;
      cuerpo.style.maxHeight = cuerpo.scrollHeight + 'px';
      item.classList.add('abierto');
      btn.setAttribute('aria-expanded', 'true');
    }

    todosItems.forEach(item => {
      const btn = item.querySelector('.nv-item-btn');
      if (!btn) return;

      btn.addEventListener('click', () => {
        const yaAbierto = item.classList.contains('abierto');

        // Cerrar todos
        todosItems.forEach(otro => {
          if (otro !== item && otro.classList.contains('abierto')) {
            cerrarItem(otro);
          }
        });

        // Toggle el actual
        if (yaAbierto) {
          cerrarItem(item);
        } else {
          abrirItem(item);
        }
      });
    });

    // --- Filtros ---
    const filtros = document.querySelectorAll('.nv-filtro');
    const semanas = document.querySelectorAll('.nv-semana');

    filtros.forEach(btn => {
      btn.addEventListener('click', () => {
        filtros.forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        const cat = (btn as HTMLElement).dataset.cat || 'todos';

        // Cerrar cualquier item abierto
        todosItems.forEach(item => cerrarItem(item));

        todosItems.forEach(item => {
          const el = item as HTMLElement;
          el.style.display = (cat === 'todos' || el.dataset.cat === cat) ? '' : 'none';
        });

        semanas.forEach(sem => {
          const visibles = sem.querySelectorAll('.nv-item:not([style*="display: none"])');
          (sem as HTMLElement).style.display = visibles.length > 0 ? '' : 'none';
        });
      });
    });
  });
</script>

