// ============================================================
// en/news.astro — Weekly tech news roundup (English)
//
// Accordion layout — title + brief desc + thumb → expands
// ============================================================
import { t } from '../../i18n/utils.js';
import Plantilla from '../../layouts/Plantilla.astro';
import Nav       from '../../components/Nav.astro';
import Footer    from '../../components/Footer.astro';
import Boton     from '../../components/Boton.astro';

const lang = 'en';

// --- Fuentes RSS en español ---
const FUENTES = [
  { nombre: 'Xataka',          url: 'https://feeds.weblogssl.com/xataka',         categoria: 'Tech' },
  { nombre: 'Genbeta',         url: 'https://feeds.weblogssl.com/genbeta',        categoria: 'Dev' },
  { nombre: 'Applesfera',      url: 'https://feeds.weblogssl.com/applesfera',     categoria: 'Apple' },
  { nombre: 'Xataka Android',  url: 'https://feeds.weblogssl.com/xatakandroid',   categoria: 'Android' },
  { nombre: 'Xataka Móvil',    url: 'https://feeds.weblogssl.com/xatakamovil',   categoria: 'Mobile' },
];

// --- Decodificar entidades HTML ---
function decodificarHTML(texto: string): string {
  const entidades: Record<string, string> = {
    '&amp;': '&', '&lt;': '<', '&gt;': '>', '&quot;': '"',
    '&apos;': "'", '&nbsp;': ' ', '&ndash;': '–', '&mdash;': '—',
    '&laquo;': '«', '&raquo;': '»', '&iexcl;': '¡', '&iquest;': '¿',
    '&ntilde;': 'ñ', '&Ntilde;': 'Ñ', '&aacute;': 'á', '&eacute;': 'é',
    '&iacute;': 'í', '&oacute;': 'ó', '&uacute;': 'ú', '&Aacute;': 'Á',
    '&Eacute;': 'É', '&Iacute;': 'Í', '&Oacute;': 'Ó', '&Uacute;': 'Ú',
    '&uuml;': 'ü', '&Uuml;': 'Ü',
  };
  let resultado = texto;
  for (const [entidad, caracter] of Object.entries(entidades)) {
    resultado = resultado.replaceAll(entidad, caracter);
  }
  resultado = resultado.replace(/&#(\d+);/g, (_, code) => String.fromCharCode(Number(code)));
  resultado = resultado.replace(/&#x([0-9a-fA-F]+);/g, (_, hex) => String.fromCharCode(parseInt(hex, 16)));
  return resultado;
}

// --- Parser RSS simple ---
function extraerEntre(xml: string, tag: string): string {
  const abre = `<${tag}`;
  const cierra = `</${tag}>`;
  const i = xml.indexOf(abre);
  if (i === -1) return '';
  const finAbre = xml.indexOf('>', i) + 1;
  const j = xml.indexOf(cierra, finAbre);
  if (j === -1) return '';
  let contenido = xml.slice(finAbre, j).trim();
  if (contenido.startsWith('<![CDATA[')) {
    contenido = contenido.slice(9, contenido.lastIndexOf(']]>'));
  }
  return contenido;
}

function extraerImagen(xml: string): string {
  const mediaMatch = xml.match(/url="([^"]+\.(jpg|jpeg|png|webp)[^"]*)"/i);
  if (mediaMatch) return mediaMatch[1];
  const encMatch = xml.match(/<enclosure[^>]+url="([^"]+)"/i);
  if (encMatch) return encMatch[1];
  const imgMatch = xml.match(/<img[^>]+src="([^"]+)"/i);
  if (imgMatch) return imgMatch[1];
  return '';
}

interface Articulo {
  titulo: string;
  descripcion: string;
  url: string;
  imagen: string;
  fecha: Date;
  fuente: string;
  categoria: string;
  minLectura: number;
}

function parsearRSS(xml: string, fuente: typeof FUENTES[0]): Articulo[] {
  const articulos: Articulo[] = [];
  const items = xml.split(/<item[\s>]/);
  for (let i = 1; i < items.length; i++) {
    const item = items[i];
    const titulo = decodificarHTML(extraerEntre(item, 'title').replace(/<[^>]*>/g, '').trim());
    const url = extraerEntre(item, 'link').replace(/<[^>]*>/g, '').trim();
    const descRaw = extraerEntre(item, 'description').replace(/<[^>]*>/g, '').trim();
    const descripcion = decodificarHTML(descRaw).slice(0, 500);
    const fechaStr = extraerEntre(item, 'pubDate');
    const fecha = fechaStr ? new Date(fechaStr) : new Date();
    const imagen = extraerImagen(item);
    if (titulo && url) {
      // ~200 palabras/min, mínimo 1 min (la desc es resumen, el artículo real es más largo)
      const palabras = descripcion.split(/\s+/).length;
      const minLectura = Math.max(2, Math.round(palabras / 40));
      articulos.push({ titulo, descripcion, url, imagen, fecha, fuente: fuente.nombre, categoria: fuente.categoria, minLectura });
    }
  }
  return articulos;
}

// --- Fetch en build time ---
const todosArticulos: Articulo[] = [];
await Promise.all(FUENTES.map(async (fuente) => {
  try {
    const res = await fetch(fuente.url, { signal: AbortSignal.timeout(8000) });
    if (!res.ok) return;
    const xml = await res.text();
    todosArticulos.push(...parsearRSS(xml, fuente));
  } catch (err) {
    console.warn(`RSS falló para ${fuente.nombre}:`, err);
  }
}));

// --- Deduplicar ---
const vistas = new Set<string>();
const unicos = todosArticulos.filter(art => {
  const clave = art.titulo.toLowerCase().slice(0, 60);
  if (vistas.has(clave)) return false;
  vistas.add(clave);
  return true;
});

// --- Agrupar por semana ---
function inicioSemana(fecha: Date): string {
  const d = new Date(fecha);
  const dia = d.getDay();
  const diff = d.getDate() - dia + (dia === 0 ? -6 : 1);
  return new Date(d.getFullYear(), d.getMonth(), diff).toISOString().split('T')[0];
}

function formatearRango(claveLunes: string): string {
  const lunes = new Date(claveLunes + 'T00:00:00');
  const domingo = new Date(lunes);
  domingo.setDate(domingo.getDate() + 6);
  const opc: Intl.DateTimeFormatOptions = { day: 'numeric', month: 'short' };
  return `${lunes.toLocaleDateString('es-AR', opc)} — ${domingo.toLocaleDateString('es-AR', opc)}, ${lunes.getFullYear()}`;
}

const hoyClaveSemanma = inicioSemana(new Date());

interface Semana { clave: string; rango: string; esActual: boolean; articulos: Articulo[]; }

const grupos: Record<string, Articulo[]> = {};
for (const art of unicos) {
  const clave = inicioSemana(art.fecha);
  if (!grupos[clave]) grupos[clave] = [];
  grupos[clave].push(art);
}

const semanas: Semana[] = Object.keys(grupos)
  .sort().reverse().slice(0, 5)
  .map(clave => ({
    clave,
    rango: formatearRango(clave),
    esActual: clave === hoyClaveSemanma,
    articulos: grupos[clave].sort((a, b) => b.fecha.getTime() - a.fecha.getTime()).slice(0, 20),
  }));

const categoriasSet = new Set(unicos.map(a => a.categoria));
const categorias = ['Todos', ...Array.from(categoriasSet)];

// ============================================================
// TIMELINE — Noticias más fuertes de meses anteriores (curadas)
// EDITAR: agregar/quitar noticias mes a mes
// ============================================================
