---
// ============================================================
// en/index.astro — Homepage (English)
// ============================================================
import { t } from '../../i18n/utils.js';
import Plantilla          from '../../layouts/Plantilla.astro';
import Nav                from '../../components/Nav.astro';
import Hero               from '../../components/Hero.astro';
import SeccionServicios   from '../../components/SeccionServicios.astro';
import SeccionStack       from '../../components/SeccionStack.astro';
import SeccionProyectos   from '../../components/SeccionProyectos.astro';
import SeccionSobre        from '../../components/SeccionSobre.astro';
import SeccionLaboratorio  from '../../components/SeccionLaboratorio.astro';
import SeccionNoticias     from '../../components/SeccionNoticias.astro';
import Footer              from '../../components/Footer.astro';
import ModalContacto       from '../../components/ModalContacto.astro';
import Boton               from '../../components/Boton.astro';

const lang = 'en';
---

<Plantilla
  titulo={t(lang, 'pagina_inicio_titulo')}
  descripcion={t(lang, 'pagina_inicio_desc')}
  lang={lang}
>
  <Nav lang={lang}/>

  <main>
    <Hero lang={lang}/>
    <SeccionServicios lang={lang}/>
    <SeccionProyectos lang={lang}/>
    <SeccionStack lang={lang}/>
    <SeccionSobre lang={lang}/>

    <!-- CTA -->
    <div class="fondo-puntos cta-contacto-wrapper">
      <canvas id="canvas-particulas-contacto" class="canvas-contacto"></canvas>
      <div class="seccion cta-contacto" id="contact">
        <span class="etiqueta">{t(lang, 'nav_contacto')}</span>
        <h2 class="titulo-dos-tonos">
          <span class="negro">{t(lang, 'cta_titulo_negro')}</span><br>
          <span class="gris">{t(lang, 'cta_titulo_gris')}</span>
        </h2>
        <p class="typewriter" data-texto={t(lang, 'cta_subtitulo')} style="max-width:420px"></p>
        <div class="cta-botones">
          <Boton data-abrir-modal="contacto">
            {t(lang, 'cta_boton_escribi')}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </Boton>
          <Boton variante="fantasma" href="https://www.linkedin.com/in/laurosa/" target="_blank" rel="noopener noreferrer">
            {t(lang, 'cta_boton_linkedin')}
          </Boton>
        </div>
      </div>
    </div>

    <SeccionLaboratorio lang={lang}/>
    <SeccionNoticias lang={lang}/>
  </main>

  <ModalContacto lang={lang}/>
  <Footer lang={lang}/>
</Plantilla>

<style>
  .cta-contacto-wrapper { position:relative; }
  .canvas-contacto { position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0; }
  .cta-contacto { display:flex;flex-direction:column;gap:20px;position:relative;z-index:1; }
  .cta-botones  { display:flex;gap:10px;flex-wrap:wrap;margin-top:4px; }
</style>
